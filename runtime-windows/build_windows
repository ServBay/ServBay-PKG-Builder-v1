#!/bin/bash
# -----------------------------------------------------------------------------
# ServBay Windows Package Build Script
# -----------------------------------------------------------------------------
#
# Purpose:
#   Automates the download, extraction, and re-packaging (into .7z format)
#   of various software packages required for the ServBay environment on Windows.
#   It reads package information from an external file and processes each entry.
#
# Usage:
#   ./build_windows <architecture> [-p <packages>]
#   Example: ./build_windows x64
#   Example: ./build_windows x64 -p php-8.3.29,php-8.4.16,node-22.22.0
#
# Arguments:
#   <architecture>: The target Windows architecture. Must be one of:
#                   arm64, x86, x64.
#   -p <packages>:  Optional. Comma-separated list of name-version pairs to build.
#                   Only matching packages will be processed. If omitted, all
#                   uncommented packages in the config file will be built.
#
# Input File:
#   windows-packages.txt (in the same directory as the script)
#   Format: One package per line, tab-separated columns:
#           PackageName  Version  [OptionalFilename]
#   Example:
#           php     8.3.5   php-8.3.5-nts-Win32-vs16-x64.zip
#           node    20.11.1
#           mysql   8.0.36
#           # Lines starting with # are ignored
#
# Dependencies:
#   - wget: For downloading files.
#   - 7z:   For extracting and compressing archives (p7zip package).
#
# Created on: Tue Apr 22, 2025
# Version: 1.0.0
#
# Copyright (c) 2022-2025 ServBay, LLC.
# Author: Sam Wu (sam@servbay.com)
# -----------------------------------------------------------------------------

# --- Configuration ---
set -eo pipefail # Exit on error, treat unset variables as error, exit on pipe fail
# set -x # Uncomment for detailed debugging

# Input architecture (first positional argument)
readonly INPUT_ARCH=$1
# Package filter (set via -p flag, comma-separated name-version pairs)
PACKAGE_FILTER=""
# Package definition file
readonly PACKAGE_FILE="windows-packages.txt"
# Base directory for build operations
readonly SERVBAY_BUILD_DIR=$(pwd)
# Directory containing source files (if any, currently unused)
# readonly SERVBAY_BUILD_SRC_DIR="${SERVBAY_BUILD_DIR}/src-windows"
# Output directory for final package files
readonly SERVBAY_BUILD_OUTPUT_DIR="${SERVBAY_BUILD_DIR}/dist-windows"
# Temporary directory for intermediate files (created per package)
readonly SERVBAY_BUILD_TEMP_BASE_DIR="${SERVBAY_BUILD_DIR}/temp-windows-build"
# Log file path
readonly LOG_FILE="${SERVBAY_BUILD_DIR}/build_windows_packages.log"
# PHP Extensions definition file
readonly PHP_EXTS_FILE="${SERVBAY_BUILD_DIR}/php-exts.json"
# Cumulative PHP Extensions installation status log file for the entire build run
readonly PHP_EXTENSIONS_STATUS_LOG_FILE="${SERVBAY_BUILD_DIR}/extensions_build_status.log"
readonly PACKAGE_RECORDS_LIB="${SERVBAY_BUILD_DIR}/build_windows_package_records.sh"

# 7z compression arguments (LZMA2, Max compression, Multi-threading)
readonly Z_COMPRESS_ARGS="a -t7z -m0=lzma2 -mx=9 -mmt=on"

if [[ ! -f "$PACKAGE_RECORDS_LIB" ]]; then
    echo "Package records helper not found: $PACKAGE_RECORDS_LIB" >&2
    exit 1
fi
source "$PACKAGE_RECORDS_LIB"

# --- Helper Functions ---

# Log messages with level
# Usage: log_message <LEVEL> <Message...>
# Example: log_message "INFO" "Starting build..."
# log_message() {
# Usage: log_message <LEVEL> <Message>
# Example: log_message "INFO" "Starting build..."
log_message() {
    local level=$1
    local message=$2
    # Basic color coding for levels (optional)
    local color_reset="\033[0m"
    local color_info="\033[0;32m" # Green
    local color_warn="\033[0;33m" # Yellow
    local color_error="\033[0;31m" # Red

    local color=""
    case "$level" in
        INFO) color="$color_info" ;;
        WARN) color="$color_warn" ;;
        ERROR) color="$color_error" ;;
    esac

    # Print to stderr to separate logs from potential script output
    >&2 echo -e "${color}[${level}] $(date '+%Y-%m-%d %H:%M:%S') - ${message}${color_reset}"

    # Append plain message to log file
    local plain_log_entry="[${level}] $(date '+%Y-%m-%d %H:%M:%S') - ${message}"
    echo "${plain_log_entry}" >> "$LOG_FILE"
}


# Check for required commands
check_command() {
    local cmd=$1
    if ! command -v "$cmd" &> /dev/null; then
        log_message "ERROR" "$cmd command not found. Please install it."
        if [[ "$cmd" == "7z" ]]; then
            log_message "INFO" "Try: brew install p7zip (macOS) or sudo apt-get install p7zip-full (Debian/Ubuntu)"
        elif [[ "$cmd" == "jq" ]]; then
            log_message "INFO" "Try: brew install jq (macOS) or sudo apt-get install jq (Debian/Ubuntu)"
        fi
        exit 1
    fi
}

# Map input architecture to common conventions
# Usage: map_arch <input_arch>
map_arch() {
    local arch_in=$1
    case "$arch_in" in
        x64) echo "x64";;        # Or sometimes amd64, x86_64
        x86) echo "x86";;        # Or sometimes win32, i386
        arm64) echo "arm64";;    # Or sometimes aarch64
        *) log_message "ERROR" "Unsupported architecture: $arch_in"; exit 1 ;;
    esac
}
# Get architecture string based on input
# Validate input architecture early
if [[ -z "$1" ]]; then
    log_message "ERROR" "Architecture argument is required. Please use one of [arm64|x86|x64]."
    echo "Usage: $0 <arm64|x86|x64>" >> "$LOG_FILE" # Also log usage error
    echo "Usage: $0 <arm64|x86|x64>" >&2
    exit 1
fi
# Check if map_arch returns a valid arch, otherwise it exits
readonly ARCH=$(map_arch "$1")
readonly ARCH_WIN_SUFFIX=$ARCH # Alias for clarity if needed

# Parse optional arguments (-p for package filter)
shift # Remove architecture argument
while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--packages)
            PACKAGE_FILTER="$2"
            shift 2
            ;;
        *)
            log_message "WARN" "Unknown argument: $1"
            shift
            ;;
    esac
done

# Download a file
# Usage: download_file <url> <output_path>
download_file() {
    local url=$1
    local output_path=$2
    log_message "INFO" "Downloading $url to $output_path"
    # Use --quiet for less verbose output, check exit code for success
    wget --quiet --show-progress -c "$url" -O "$output_path"
    local exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        log_message "ERROR" "Failed to download $url (wget exit code: $exit_code). Check $LOG_FILE for details."
        # Clean up potentially incomplete download
        rm -f "$output_path" 2>/dev/null || true
        return 1
    fi
    log_message "INFO" "Download successful."
    return 0
}

# Extract an archive
# Usage: extract_archive <archive_path> <extract_dir>
extract_archive() {
    local archive_path=$1
    local extract_dir=$2
    local exit_code=0
    local extract_output=""
    local tool_used=""

    # Check if archive file exists
    if [[ ! -f "$archive_path" ]]; then
        log_message "ERROR" "Archive file not found for extraction: $archive_path"
        return 1
    fi

    log_message "INFO" "Extracting $archive_path to $extract_dir"

    # Ensure extraction directory exists
    mkdir -p "$extract_dir" || { log_message "ERROR" "Failed to create extraction directory: $extract_dir"; return 1; }

    # Check file extension (basename) and use appropriate tool
    local filename=$(basename "$archive_path")
    case "$filename" in
        *.tar.gz|*.tgz)
            tool_used="tar (gzip)"
            # -x: extract, -z: gzip, -f: file, -C: change to directory
            tar -xzf "$archive_path" -C "$extract_dir" >> "$LOG_FILE" 2>&1
            exit_code=$?
            ;;
        *.tar.bz2|*.tbz2)
            tool_used="tar (bzip2)"
            # -j: bzip2
            tar -xjf "$archive_path" -C "$extract_dir" >> "$LOG_FILE" 2>&1
            exit_code=$?
            ;;
        *.tar.xz|*.txz)
            tool_used="tar (xz)"
            # -J: xz
            tar -xJf "$archive_path" -C "$extract_dir" >> "$LOG_FILE" 2>&1
            exit_code=$?
            ;;
        *.zip|*.7z|*.rar|*.exe|*.tar) # Add other types 7z handles well, including plain .tar
             tool_used="7z"
             # -aoa: Overwrite existing files without prompt
             7z x "$archive_path" -o"$extract_dir" -aoa >> "$LOG_FILE" 2>&1
             exit_code=$?
            ;;
        *)
            log_message "ERROR" "Unsupported archive type based on filename suffix: $filename"
            return 1
            ;;
    esac

    # Check exit code
    if [[ $exit_code -ne 0 ]]; then
        log_message "ERROR" "Failed to extract $archive_path using $tool_used (Exit code: $exit_code). Check $LOG_FILE for details."
        return 1
    # Optional: Check tar/7z output for specific error strings even if exit code is 0
    # This requires reading the log file, might be complex. Relying on exit code for now.
    fi

    log_message "INFO" "Extraction successful using $tool_used."
    return 0 # Explicitly return 0 on success
}

# Compress a directory's contents
# Usage: compress_directory <source_dir> <output_archive>
compress_directory() {
    local source_dir=$1
    local output_archive=$2
    log_message "INFO" "Compressing contents of $source_dir to $output_archive"
    # Ensure source directory exists
    if [[ ! -d "$source_dir" ]]; then
        log_message "ERROR" "Source directory for compression does not exist: $source_dir"
        return 1
    fi

    # Change to source directory to avoid including parent folders in the archive
    pushd "$source_dir" > /dev/null
    if [[ $? -ne 0 ]]; then
        log_message "ERROR" "Failed to change directory to $source_dir"
        # Try to pop back even on failure
        popd > /dev/null 2>&1 || true
        return 1
    fi

    # Compress contents (dot .)
    7z ${Z_COMPRESS_ARGS} "$output_archive" .
    local exit_code=$?

    # Pop back regardless of compression success/failure
    popd > /dev/null

    if [[ $exit_code -ne 0 ]]; then
        log_message "ERROR" "Failed to compress $output_archive (Exit code: $exit_code)"
        # Clean up potentially incomplete archive
        rm -f "$output_archive" 2>/dev/null || true
        return 1
    fi
    log_message "INFO" "Compression successful."
    return 0
}

# Compress a directory's contents OR a single file
# Usage: compress_item <source_item> <output_archive>
compress_item() {
    local source_item=$1 # Can be a directory or a file
    local output_archive=$2
    local source_basename=$(basename "$source_item")

    # Check if source exists
    if [[ ! -e "$source_item" ]]; then
        log_message "ERROR" "Source item for compression does not exist: $source_item"
        return 1
    fi

    if [[ -d "$source_item" ]]; then
        log_message "INFO" "Compressing contents of directory $source_item to $output_archive"
        # Change to source directory to avoid including parent folders in the archive
        pushd "$source_item" > /dev/null
        if [[ $? -ne 0 ]]; then
            log_message "ERROR" "Failed to change directory to $source_item"
            popd > /dev/null 2>&1 || true
            return 1
        fi
        # Compress contents (dot .)
        7z ${Z_COMPRESS_ARGS} "$output_archive" .
        local exit_code=$?
        popd > /dev/null # Pop back regardless of compression success/failure
    elif [[ -f "$source_item" ]]; then
        log_message "INFO" "Compressing file $source_item to $output_archive"
        # Change to directory containing the file to control the path inside the archive
        local source_dir=$(dirname "$source_item")
        pushd "$source_dir" > /dev/null
         if [[ $? -ne 0 ]]; then
            log_message "ERROR" "Failed to change directory to $source_dir"
            popd > /dev/null 2>&1 || true
            return 1
        fi
        # Compress just the file
        7z ${Z_COMPRESS_ARGS} "$output_archive" "$source_basename"
        local exit_code=$?
        popd > /dev/null # Pop back regardless of compression success/failure
    else
        log_message "ERROR" "Source item is not a file or directory: $source_item"
        return 1
    fi


    if [[ $exit_code -ne 0 ]]; then
        log_message "ERROR" "Failed to compress $source_basename into $output_archive (Exit code: $exit_code)"
        # Clean up potentially incomplete archive
        rm -f "$output_archive" 2>/dev/null || true
        return 1
    fi
    log_message "INFO" "Compression successful."
    return 0
}

# Clean up temporary files and directories for a specific package
# Usage: cleanup_package_temp <package_temp_dir>
cleanup_package_temp() {
    local package_temp_dir=$1

    if [[ -n "$package_temp_dir" && -d "$package_temp_dir" ]]; then
        log_message "INFO" "Cleaning up temporary directory: $package_temp_dir"
        rm -rf "$package_temp_dir"
        if [[ $? -ne 0 ]]; then
             log_message "WARN" "Failed to completely remove temporary directory: $package_temp_dir"
        fi
    fi
}

# Clean up the base temporary directory at the end
# Usage: cleanup_base_temp <base_temp_dir>
cleanup_base_temp() {
     local base_temp_dir=$1
     if [[ -n "$base_temp_dir" && -d "$base_temp_dir" ]]; then
        log_message "INFO" "Cleaning up base temporary directory: $base_temp_dir"
        rm -rf "$base_temp_dir"
         if [[ $? -ne 0 ]]; then
             log_message "WARN" "Failed to completely remove base temporary directory: $base_temp_dir"
        fi
    fi
}

