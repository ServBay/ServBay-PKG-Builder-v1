# --- Main Execution ---
BUILD_WINDOWS_SH=$(pwd)/build_windows.sh
# Initialize Log File (clear or create)
echo "Initializing build log at $LOG_FILE..." > "$LOG_FILE"
# Ensure log directory exists (though it's in PWD here)
mkdir -p "$(dirname "$LOG_FILE")"

log_message "INFO" "Starting Windows package build for architecture: $ARCH"
log_message "INFO" "Build directory: $SERVBAY_BUILD_DIR"
log_message "INFO" "Output directory: $SERVBAY_BUILD_OUTPUT_DIR"
log_message "INFO" "Temporary directory: $SERVBAY_BUILD_TEMP_BASE_DIR"
log_message "INFO" "Log file: $LOG_FILE"
if [[ -n "$PACKAGE_FILTER" ]]; then
    log_message "INFO" "Package filter: $PACKAGE_FILTER"
fi

# Check dependencies
check_command "wget"
check_command "7z"
check_command "tar" # Add tar check
check_command "gzip" # Tar dependency
check_command "bzip2" # Tar dependency
check_command "xz" # Tar dependency
check_command "jq"   # For parsing JSON

# Check if package file exists
if [[ ! -f "$PACKAGE_FILE" ]]; then
    log_message "ERROR" "Package definition file not found: $PACKAGE_FILE"
    exit 1
fi

# Clean or Create temporary directory base
# Check if base temp dir exists and remove it first
if [ -d "$SERVBAY_BUILD_TEMP_BASE_DIR" ]; then
    log_message "INFO" "Removing existing temporary base directory: $SERVBAY_BUILD_TEMP_BASE_DIR"
    rm -rf "$SERVBAY_BUILD_TEMP_BASE_DIR"
    if [ $? -ne 0 ]; then
        log_message "ERROR" "Failed to remove existing temporary base directory. Check permissions or processes using it."
        exit 1
    fi
fi
mkdir -p "$SERVBAY_BUILD_TEMP_BASE_DIR"
if [ $? -ne 0 ]; then
    log_message "ERROR" "Failed to create temporary base directory: $SERVBAY_BUILD_TEMP_BASE_DIR"
    exit 1
fi
log_message "INFO" "Created temporary base directory: $SERVBAY_BUILD_TEMP_BASE_DIR"

PACKAGE_RECORDS_FILE="${SERVBAY_BUILD_TEMP_BASE_DIR}/package-records.tsv"
if ! resolve_windows_package_records "$PACKAGE_FILE" "$PACKAGE_FILTER" > "$PACKAGE_RECORDS_FILE"; then
    log_message "ERROR" "Failed to resolve requested package records from $PACKAGE_FILE"
    exit 1
fi

# --- Process Package File ---
build_errors=0
total_packages=0
built_packages=0
processed_lines=0

# Use awk to filter and then a while read loop for portability
# Set IFS specifically for the read command to handle tabs correctly.
# Use printf '\t' for portability instead of $'\t' if needed, but $'\t' is common in modern bash.
# read -r prevents backslash interpretation
# || [[ -n "$line" ]] handles the case where the last line might not have a newline
while IFS=$'\t' read -r -a fields || [[ -n "${fields[0]}" ]]; do
    processed_lines=$((processed_lines + 1))

    # Check if fields array has at least 2 elements (name and version)
    if [[ ${#fields[@]} -lt 2 ]]; then
        # Read the raw line again if fields array is empty/incomplete, to log it
        # This part is tricky as the original line might be lost depending on how read failed
        # Let's assume if fields[0] is empty, the line was likely empty or whitespace
        if [[ -z "${fields[0]}" ]]; then
             log_message "WARN" "Skipping empty or whitespace line number $processed_lines."
        else
             # Log the first field if available, indicating potential format issue
             log_message "WARN" "Skipping potentially malformed line $processed_lines (starts with: '${fields[0]}'). Ensure TAB separation."
        fi
        continue
    fi

    package_name="${fields[0]}"
    package_version="${fields[1]}"
    # Assign filename only if it exists (index 2)
    package_filename=""
    if [[ ${#fields[@]} -ge 3 ]]; then
        package_filename="${fields[2]}"
    fi

    # Trim potential whitespace (using parameter expansion for portability)
    # Note: IFS handling in read -a should prevent leading/trailing whitespace *within* fields if IFS is just tab.
    # But let's keep it for safety, especially for the filename which might have spaces if not quoted.
    package_name="${package_name#"${package_name%%[![:space:]]*}"}" # remove leading
    package_name="${package_name%"${package_name##*[![:space:]]}"}" # remove trailing
    package_version="${package_version#"${package_version%%[![:space:]]*}"}"
    package_version="${package_version%"${package_version##*[![:space:]]}"}"
    package_filename="${package_filename#"${package_filename%%[![:space:]]*}"}"
    package_filename="${package_filename%"${package_filename##*[![:space:]]}"}"

    # Re-check after trimming if name or version became empty
    if [[ -z "$package_name" || -z "$package_version" ]]; then
        log_message "WARN" "Skipping line $processed_lines after trimming; missing package name or version."
        continue
    fi

    total_packages=$((total_packages + 1)) # Increment count only for valid-looking lines

    # Apply package filter if set (-p flag)
    if [[ -n "$PACKAGE_FILTER" ]]; then
        filter_key="${package_name}-${package_version}"
        if [[ ",$PACKAGE_FILTER," != *",$filter_key,"* ]]; then
            continue
        fi
    fi

    # Construct function name
    # Replace hyphens and dots with underscores for function names
    build_function_name="Build_Package_$(echo "${package_name}" | tr '.-' '__')"

    # Check if the build function exists
    if declare -f "$build_function_name" > /dev/null; then
        log_message "INFO" "Attempting to build: $package_name $package_version ($ARCH)"
        # Call the function for the package
        if "$build_function_name" "$package_name" "$package_version" "$package_filename"; then
            # Success logged within the function
            built_packages=$((built_packages + 1))
        else
            # Error logged within the function
            build_errors=$((build_errors + 1))
            # Optional: Stop on first error? Add 'exit 1' here if needed.
        fi
    else
        log_message "WARN" "No build function defined for '$package_name' (tried '$build_function_name'). Skipping."
        # Optionally count this as an error?
        # ((build_errors++))
    fi

    # Clear fields array for the next iteration (good practice)
    unset fields

done < "$PACKAGE_RECORDS_FILE"


# Final Summary
log_message "INFO" "=============================================="
log_message "INFO" "Build process completed."
log_message "INFO" "Attempted to process $total_packages package entries from $processed_lines lines read."
log_message "INFO" "Successfully built packages: $built_packages"
if [[ $build_errors -gt 0 ]]; then
    log_message "ERROR" "$build_errors package(s) failed to build."
    log_message "INFO" "Check log file for details: $LOG_FILE"
    # cleanup_base_temp "$SERVBAY_BUILD_TEMP_BASE_DIR" # Optional: Leave temp dir on failure for debugging
    exit 1 # Exit with error code if any builds failed
else
    log_message "INFO" "All attempted packages built successfully!"
    log_message "INFO" "Log file available at: $LOG_FILE"
    # Clean up base temp dir on success
    cleanup_base_temp "$SERVBAY_BUILD_TEMP_BASE_DIR"
    exit 0
fi
