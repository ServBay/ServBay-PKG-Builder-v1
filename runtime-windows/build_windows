# simple-acme with all DNS plugins
Build_Package_simple_acme() {
    local package_name=$1
    local package_version=$2 # 例如: 2.3.5

    # simple-acme 提供 x86, x64, arm64 三个架构
    case "$ARCH" in
        x64|x86|arm64) ;;
        *) log_message "ERROR" "Unsupported simple-acme architecture: $ARCH"; return 1 ;;
    esac

    log_message "INFO" "=============================================="
    log_message "INFO" "Building simple-acme Package: $package_name"
    log_message "INFO" "Version: $package_version, Arch: $ARCH"
    log_message "INFO" "=============================================="

    # --- 通过 GitHub API 动态发现资产文件名（含构建号） ---
    local api_url="https://api.github.com/repos/simple-acme/simple-acme/releases/tags/v${package_version}"
    log_message "INFO" "Querying GitHub API for release assets: ${api_url}"
    local release_json
    release_json=$(curl -s "$api_url")
    if [[ -z "$release_json" ]] || ! echo "$release_json" | jq -e '.assets | length > 0' &>/dev/null; then
        log_message "ERROR" "Failed to fetch release info from GitHub API for v${package_version}"
        return 1
    fi

    # 找到主程序文件名（匹配 win-${ARCH}.pluggable.zip）
    local main_program_filename
    main_program_filename=$(echo "$release_json" | jq -r ".assets[].name | select(test(\"win-${ARCH}\\\\.pluggable\\\\.zip$\"))" | head -1)

    if [[ -z "$main_program_filename" ]]; then
        log_message "ERROR" "Could not find main program asset for architecture $ARCH in release v${package_version}"
        return 1
    fi
    log_message "INFO" "Found main program: $main_program_filename"

    # 从 release assets 中动态发现所有 DNS 验证插件
    local plugins_list=()
    while IFS= read -r plugin_name; do
        [[ -n "$plugin_name" ]] && plugins_list+=("$plugin_name")
    done < <(echo "$release_json" | jq -r '.assets[].name | select(startswith("plugin.validation.dns."))')

    log_message "INFO" "Found ${#plugins_list[@]} DNS validation plugins"

    # --- 定义变量 ---
    local output_filename_base="simple-acme-${package_version}"

    # 定义构建过程中使用的路径
    local package_output_dir="${SERVBAY_BUILD_OUTPUT_DIR}/${package_name}/${ARCH}"
    local safe_version=$(echo "$package_version" | tr '/' '_')
    local package_temp_dir="${SERVBAY_BUILD_TEMP_BASE_DIR}/${package_name}-${safe_version}-${ARCH}"
    local main_archive_temp_path="${package_temp_dir}/${main_program_filename}"
    local extract_root_dir="${package_temp_dir}/unzip"
    local plugins_target_dir="${extract_root_dir}/plugins"
    local final_package_file="${package_output_dir}/${output_filename_base}-windows-${ARCH}.7z"

    # GitHub Releases 的基础下载 URL
    local base_download_url="https://github.com/simple-acme/simple-acme/releases/download/v${package_version}"

    # --- 开始构建流程 ---
    local build_failed=0

    # 创建所需的目录
    mkdir -p "$package_output_dir"
    rm -rf "$package_temp_dir"
    mkdir -p "$package_temp_dir"
    mkdir -p "$extract_root_dir"

    # 1. 下载并解压主程序
    log_message "INFO" "Downloading main program: ${main_program_filename}"
    if ! download_file "${base_download_url}/${main_program_filename}" "$main_archive_temp_path"; then
        build_failed=1
    fi

    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Extracting main program..."
        # 主程序的 zip 文件直接包含其内容，所以解压到我们的根目录
        if ! extract_archive "$main_archive_temp_path" "$extract_root_dir"; then
            build_failed=1
        fi
    fi

    # 2. 创建 plugins 目录，并下载和解压所有插件
    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Creating plugins directory at: ${plugins_target_dir}"
        mkdir -p "$plugins_target_dir" || { log_message "ERROR" "Failed to create plugins directory."; build_failed=1; }
    fi

    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Processing ${#plugins_list[@]} plugins..."
        for plugin_filename in "${plugins_list[@]}"; do
            local plugin_url="${base_download_url}/${plugin_filename}"
            local plugin_archive_path="${package_temp_dir}/${plugin_filename}"

            log_message "INFO" "Downloading plugin: ${plugin_filename}"
            if download_file "$plugin_url" "$plugin_archive_path"; then
                log_message "INFO" "Extracting ${plugin_filename} directly into ${plugins_target_dir}"
                # 将插件压缩包的内容直接解压到最终的 plugins 文件夹中
                if ! extract_archive "$plugin_archive_path" "$plugins_target_dir"; then
                    log_message "ERROR" "Failed to extract plugin: ${plugin_filename}. Build will continue but this plugin will be missing."
                fi
            else
                log_message "ERROR" "Failed to download plugin: ${plugin_filename}. Build will continue but this plugin will be missing."
            fi
        done
    fi

    # 3. 压缩最终的包
    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Compressing final package to ${final_package_file}"
        if ! compress_directory "$extract_root_dir" "$final_package_file"; then
            build_failed=1
        fi
    fi

    # 4. 清理临时文件
    cleanup_package_temp "$package_temp_dir"

    # --- 最终状态报告 ---
    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Successfully built simple-acme package $package_name $package_version for $ARCH."
        return 0
    else
        log_message "ERROR" "Failed build steps for simple-acme package $package_name $package_version for $ARCH."
        # 如果构建失败，删除可能已创建的不完整的最终文件
        rm -f "$final_package_file" 2>/dev/null || true
        return 1
    fi
}

