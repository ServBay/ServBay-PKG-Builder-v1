# --- Package Build Functions ---

# Generic build process for standard archive packages
# Usage: Build_Package_Generic <pkg_name> <pkg_version> <download_url> <original_filename> <extract_subdir> [output_filename_base] [post_extract_cmds]
#   <original_filename>: The actual filename of the downloaded archive (e.g., xyz.tar.gz)
#   <extract_subdir>: Path *inside* the archive to compress (use "." if root)
#   [output_filename_base]: Base name for the output .7z file (defaults to <pkg_name>-<pkg_version>)
#   [post_extract_cmds]: Optional string of commands to run in extracted dir before compression (e.g., "rm -f file.pdb")
Build_Package_Generic() {
    local package_name=$1
    local package_version=$2
    local download_url=$3
    local original_filename=$4
    local extract_subdir=$5 # Subdirectory inside the archive to cd into before compressing, or "." for root
    local output_filename_base=${6:-"${package_name}-${package_version}"} # Optional: base name for output file
    local post_extract_cmds=${7:-""} # Optional: post-extraction commands

    if [[ -z "$original_filename" ]]; then
        log_message "ERROR" "[Build_Package_Generic] Original filename cannot be empty for $package_name $package_version."
        return 1
    fi

    log_message "INFO" "=============================================="
    log_message "INFO" "Building Generic Package: $package_name"
    log_message "INFO" "Version: $package_version, Arch: $ARCH"
    log_message "INFO" "Download URL: $download_url"
    log_message "INFO" "Original Filename: $original_filename"
    if [[ -n "$post_extract_cmds" ]]; then
      log_message "INFO" "Post-Extract Commands: $post_extract_cmds"
    fi
    log_message "INFO" "=============================================="

    local package_output_dir="${SERVBAY_BUILD_OUTPUT_DIR}/${package_name}/${ARCH}"
    # Ensure temp dir name is filesystem-safe (replace potential slashes in version etc.)
    local safe_version=$(echo "$package_version" | tr '/' '_')
    local package_temp_dir="${SERVBAY_BUILD_TEMP_BASE_DIR}/${package_name}-${safe_version}-${ARCH}"
    local package_temp_save_path="${package_temp_dir}/${original_filename}"
    local package_save_filename="${package_output_dir}/${output_filename_base}-windows-${ARCH}.7z"
    local package_unzip_dir="${package_temp_dir}/unzip"

    # Create directories
    mkdir -p "$package_output_dir"
    # Clean potential previous temp dir for this specific package before creating
    rm -rf "$package_temp_dir"
    mkdir -p "$package_temp_dir" # Create base temp dir first
    mkdir -p "$package_unzip_dir" # Create unzip dir within temp dir

    local build_failed=0

    # Download - Save with original filename in temp dir
    if ! download_file "$download_url" "$package_temp_save_path"; then
        build_failed=1
    fi

    # Extract (only if download succeeded) - Use the path with the original filename
    if [[ $build_failed -eq 0 ]]; then
        if ! extract_archive "$package_temp_save_path" "$package_unzip_dir"; then
            build_failed=1
        fi
    fi

    # Determine the directory to compress (only if extraction succeeded)
    local dir_to_compress=""
    if [[ $build_failed -eq 0 ]]; then
        dir_to_compress="${package_unzip_dir}/${extract_subdir}"
        # If extract_subdir is ".", use the unzip directory directly
        if [[ "$extract_subdir" == "." ]]; then
            dir_to_compress="$package_unzip_dir"
        elif [[ ! -d "$dir_to_compress" ]]; then
            # Handle cases where the top-level directory name might vary slightly
            log_message "INFO" "Expected subdir '$extract_subdir' not found. Searching within '$package_unzip_dir'..."
            local found_dirs
            # Find directories, handle potential spaces/special chars in names correctly with null delimiter
            if command -v mapfile >/dev/null; then
                 mapfile -d '' found_dirs_array < <(find "$package_unzip_dir" -maxdepth 1 -mindepth 1 -type d -print0)
                 local num_found=${#found_dirs_array[@]}
            else
                # Alternative for older bash without mapfile
                local find_output=$(find "$package_unzip_dir" -maxdepth 1 -mindepth 1 -type d -print)
                local num_found=$(echo "$find_output" | wc -l | xargs) # Count lines/dirs found
                if [[ "$num_found" -eq 1 ]]; then
                    found_dirs_array=("$find_output")
                fi
            fi

            if [[ "$num_found" -eq 1 ]]; then
                 # Remove null terminator if mapfile was used
                 local found_dir=${found_dirs_array[0]%$'\0'}
                 log_message "WARN" "Using automatically detected directory '$found_dir' instead."
                 dir_to_compress="$found_dir"
            elif [[ "$num_found" -gt 1 ]]; then
                log_message "ERROR" "Multiple directories found in '$package_unzip_dir', cannot determine extraction root. Found:"
                 if command -v mapfile >/dev/null; then
                    printf " - %s\n" "${found_dirs_array[@]}"
                 else
                    echo "$find_output" # Less safe printing
                 fi
                build_failed=1
            else # num_found is 0 or find failed
                log_message "ERROR" "Extraction subdirectory '$extract_subdir' not found, and no other directory found in '$package_unzip_dir'!"
                build_failed=1
            fi
        fi
    fi

    # *** NEW: Run Post-Extraction Commands (only if extraction succeeded and dir is valid) ***
    if [[ $build_failed -eq 0 && -n "$post_extract_cmds" && -d "$dir_to_compress" ]]; then
        log_message "INFO" "Running post-extraction commands in $dir_to_compress..."
        pushd "$dir_to_compress" > /dev/null
        if [[ $? -ne 0 ]]; then
            log_message "ERROR" "Failed to change directory to $dir_to_compress for post-extraction commands."
            popd > /dev/null 2>&1 || true
            build_failed=1
        else
            # Execute the commands using eval (use with caution)
            eval "$post_extract_cmds"
            local cmd_exit_code=$?
            popd > /dev/null # Pop back regardless of command success

            if [[ $cmd_exit_code -ne 0 ]]; then
                log_message "ERROR" "Post-extraction commands failed with exit code $cmd_exit_code."
                build_failed=1
            else
                 log_message "INFO" "Post-extraction commands completed successfully."
            fi
        fi
    fi

    # Compress (only if all previous steps succeeded and directory to compress exists)
    if [[ $build_failed -eq 0 ]]; then
         if [[ ! -d "$dir_to_compress" ]]; then
              log_message "ERROR" "Directory to compress '$dir_to_compress' does not exist (check post-extract commands?)."
              build_failed=1
         elif ! compress_directory "$dir_to_compress" "$package_save_filename"; then
            build_failed=1
        fi
    fi

    # Cleanup the specific package temp directory regardless of success/failure
    cleanup_package_temp "$package_temp_dir"

    # Check final status
    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Successfully built package $package_name $package_version for $ARCH."
        return 0 # Success
    else
        log_message "ERROR" "Failed build steps for package $package_name $package_version for $ARCH."
        # Ensure partially created final file is removed on failure
        rm -f "$package_save_filename" 2>/dev/null || true
        return 1 # Failure
    fi
}

# Build process for single-file tools (download and compress)
# Usage: Build_Package_SingleFile <pkg_name> <pkg_version> <download_url> <original_filename> [output_filename_base]
#   <original_filename>: The actual filename to save the download as (e.g., composer.phar)
#   [output_filename_base]: Base name for the output .7z file (defaults to <pkg_name>-<pkg_version>)
# Build_Package_SingleFile <pkg_name> <pkg_version> <download_url> <origin_filename> <rename_filename> [output_filename_base]
Build_Package_SingleFile() {
    local package_name=$1
    local package_version=$2
    local download_url=$3
    local original_filename=$4 # The actual filename to save the download as
    local rename_filename=${5:-"${original_filename}"}
    local output_filename_base=${6:-"${package_name}-${package_version}"} # Optional: base name for output file


    if [[ -z "$original_filename" ]]; then
        log_message "ERROR" "[Build_Package_SingleFile] Original filename cannot be empty for $package_name $package_version."
        return 1
    fi

    log_message "INFO" "=============================================="
    log_message "INFO" "Building Single File Package: $package_name"
    log_message "INFO" "Version: $package_version, Arch: $ARCH (N/A)"
    log_message "INFO" "Download URL: $download_url, Save As: $rename_filename"
    log_message "INFO" "Original Filename: $original_filename"
    log_message "INFO" "=============================================="

    # Output directory (arch-independent for these tools)
    local package_output_dir="${SERVBAY_BUILD_OUTPUT_DIR}/${package_name}/$ARCH"
    # Temporary directory for this package
    local safe_version=$(echo "$package_version" | tr '/' '_')
    local package_temp_dir="${SERVBAY_BUILD_TEMP_BASE_DIR}/${package_name}-${safe_version}-singlefile"
    # Path to save the downloaded file temporarily
    local package_temp_save_path="${package_temp_dir}/${rename_filename}"
    # Final compressed output file path
    local package_save_filename="${package_output_dir}/${output_filename_base}-windows-$ARCH.7z"

    # Create directories
    mkdir -p "$package_output_dir"
    rm -rf "$package_temp_dir"
    mkdir -p "$package_temp_dir"

    local build_failed=0

    # Download directly to the temporary location with original filename
    if ! download_file "$download_url" "$package_temp_save_path"; then
        build_failed=1
    fi

    # Compress the single downloaded file (only if download succeeded)
    if [[ $build_failed -eq 0 ]]; then
        # Use compress_item which handles single files
        if ! compress_item "$package_temp_save_path" "$package_save_filename"; then
            build_failed=1
        fi
    fi

    # Cleanup the specific package temp directory regardless of success/failure
    cleanup_package_temp "$package_temp_dir"

     # Check final status
    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Successfully built single-file package $package_name $package_version."
        return 0 # Success
    else
        log_message "ERROR" "Failed build steps for single-file package $package_name $package_version."
        # Ensure partially created final file is removed on failure
        rm -f "$package_save_filename" 2>/dev/null || true
        return 1 # Failure
    fi
}

# PHP
Build_Package_php() {
    local package_name=$1
    local package_version=$2
    local package_filename=$3 # Provided in input file (only used for legacy PHP <= 8.0)
    local output_filename_base="php-${package_version}"

    log_message "INFO" "=============================================="
    log_message "INFO" "Building PHP Package: $package_name"
    log_message "INFO" "Version: $package_version, Arch: $ARCH"
    log_message "INFO" "=============================================="

    local package_output_dir="${SERVBAY_BUILD_OUTPUT_DIR}/${package_name}/${ARCH}"
    local safe_version=$(echo "$package_version" | tr '/' '_')
    local package_temp_dir="${SERVBAY_BUILD_TEMP_BASE_DIR}/${package_name}-${safe_version}-${ARCH}"
    # Final compressed output file path for PHP
    local final_php_package_file="${package_output_dir}/${output_filename_base}-windows-${ARCH}.7z"

    # Create directories
    mkdir -p "$package_output_dir"
    rm -rf "$package_temp_dir"
    mkdir -p "$package_temp_dir"

    local build_failed=0
    local package_major_version=${package_version%.*} # x.x

    # Determine if this version uses pre-built packages from ServBay/PHP-Windows-Portable
    # PHP 8.1+ uses pre-built packages with extensions already compiled in
    # PHP 8.0 and below uses standard builds from windows.php.net with separate ext processing
    local use_prebuilt=0
    case "$package_major_version" in
        5.*|7.*|8.0) use_prebuilt=0 ;;
        *) use_prebuilt=1 ;;
    esac

    if [[ $use_prebuilt -eq 1 ]]; then
        # PHP 8.1+ from ServBay custom build (extensions already included, pre-packaged as 7z)
        local github_filename="php-${package_version}-windows-${ARCH}.7z"
        local php_download_url="https://github.com/ServBay/PHP-Windows-Portable/releases/download/php-${package_version}-${ARCH}-nts/${github_filename}"
        log_message "INFO" "Using pre-built package from ServBay/PHP-Windows-Portable"
        log_message "INFO" "Download URL: $php_download_url"

        # Download directly to final output location (no extraction/repackaging needed)
        if ! download_file "$php_download_url" "$final_php_package_file"; then
            build_failed=1
            log_message "ERROR" "Failed to download pre-built PHP package."
        else
            log_message "INFO" "Successfully downloaded pre-built PHP package to $final_php_package_file"
        fi
    else
        # Standard PHP builds from windows.php.net (PHP 8.0 and below) - need extraction, ext processing and repackaging
        if [[ -z "$package_filename" ]]; then
            log_message "ERROR" "Filename is required for PHP package in windows-packages.txt"
            return 1
        fi

        log_message "INFO" "Original PHP Filename: $package_filename"

        # Path for the main PHP archive
        local php_archive_temp_path="${package_temp_dir}/${package_filename}"
        # Directory where main PHP will be extracted
        local php_extract_root_dir="${package_temp_dir}/php_root"
        mkdir -p "$php_extract_root_dir"

        local outdated_versions="5.3 5.4 5.5 5.6 7.0 7.1 7.2 7.3 "
        local base_url="https://windows.php.net/downloads/releases/"
        if [[ " $outdated_versions " =~ " $package_major_version " ]]; then
            base_url="https://windows.php.net/downloads/releases/archives/"
        fi
        local php_download_url="${base_url}${package_filename}"

        log_message "INFO" "PHP Download URL: $php_download_url"

        if ! download_file "$php_download_url" "$php_archive_temp_path"; then
            build_failed=1
        fi

        if [[ $build_failed -eq 0 ]]; then
            # PHP zips from windows.php.net extract their contents directly
            if ! extract_archive "$php_archive_temp_path" "$php_extract_root_dir"; then
                build_failed=1
            fi
        fi

        # --- 2. Process PHP Extensions ---
        if [[ $build_failed -eq 0 ]]; then
            local php_ext_target_dir="${php_extract_root_dir}/ext"
            log_message "INFO" "PHP Ext Target Dir: $php_ext_target_dir"
            mkdir -p "$php_ext_target_dir" || { log_message "ERROR" "Failed to create PHP ext directory: $php_ext_target_dir"; build_failed=1; }

            if [[ ! -f "$PHP_EXTS_FILE" ]]; then
                log_message "WARN" "PHP extensions definition file not found: $PHP_EXTS_FILE. Skipping extension installation logging."
            elif [[ $build_failed -eq 0 ]]; then
            local php_major_minor_ver=$(echo "$package_version" | cut -d. -f1-2)
            log_message "INFO" "Processing extensions for PHP $php_major_minor_ver ($ARCH)..."

            # Append header for this PHP version to the cumulative extensions status log
            echo -e "\n[Addtional Extensions for PHP ${php_major_minor_ver} ($ARCH)]" >> "$PHP_EXTENSIONS_STATUS_LOG_FILE"
            if [[ $? -ne 0 ]]; then
                log_message "ERROR" "Failed to write header to PHP extensions status log: $PHP_EXTENSIONS_STATUS_LOG_FILE"
            fi
            for ext_name in "${REQUIRED_PHP_EXTENSIONS_LIST[@]}"; do
                log_message "INFO" "Looking for extension: $ext_name for PHP $php_major_minor_ver ($ARCH)"
                local ext_info_json
                ext_info_json=$(jq -r --arg ext_name "$ext_name" --arg php_ver "$php_major_minor_ver" --arg arch_target "$ARCH" \
                    '.[$ext_name]?[$php_ver]? | select(.arch == $arch_target) // empty' "$PHP_EXTS_FILE")

                if [[ -z "$ext_info_json" ]]; then
                    log_message "WARN" "PHP Extension Missing: ${ext_name} for PHP ${package_version} (${ARCH}). Not found in ${PHP_EXTS_FILE} for PHP $php_major_minor_ver."
                    echo "; extension=${ext_name}" >> "$PHP_EXTENSIONS_STATUS_LOG_FILE"
                    continue
                fi

                local ext_download_url=$(echo "$ext_info_json" | jq -r '.download_url')

                if [[ -z "$ext_download_url" || "$ext_download_url" == "null" ]]; then
                    log_message "WARN" "PHP Extension Data Incomplete: ${ext_name} for PHP ${package_version} (${ARCH}). No download_url."
                    echo "; extension=${ext_name}" >> "$PHP_EXTENSIONS_STATUS_LOG_FILE"
                    continue
                fi

                log_message "INFO" "Found ${ext_name}: ${ext_download_url}"

                local ext_temp_process_dir="${package_temp_dir}/_ext_processing/${ext_name}"
                rm -rf "$ext_temp_process_dir"
                mkdir -p "$ext_temp_process_dir"

                local ext_archive_filename=$(basename "$ext_download_url")
                local ext_archive_path="${ext_temp_process_dir}/${ext_archive_filename}"
                local ext_unzip_dir="${ext_temp_process_dir}/unzip"

                local current_ext_install_ok=0 # Flag for current extension success

                if download_file "$ext_download_url" "$ext_archive_path"; then
                    if extract_archive "$ext_archive_path" "$ext_unzip_dir"; then
                        # 特殊处理 memcached 和 imagick 扩展
                        if [[ "$ext_name" == "memcached" || "$ext_name" == "imagick" ]]; then
                            log_message "INFO" "Processing $ext_name extension with special rules..."
                            local files_copied=0
                            local php_ext_dll_name="php_${ext_name}.dll"

                            # 拷贝 php_*.dll 到 ext 目录
                            local php_ext_dll
                            php_ext_dll=$(find "$ext_unzip_dir" -maxdepth 1 -name "$php_ext_dll_name" -print -quit)
                            if [[ -n "$php_ext_dll" && -f "$php_ext_dll" ]]; then
                                log_message "INFO" "Copying $php_ext_dll_name to $php_ext_target_dir/"
                                if cp "$php_ext_dll" "$php_ext_target_dir/" >> "$LOG_FILE" 2>&1; then
                                    files_copied=1
                                else
                                    log_message "ERROR" "Failed to copy $php_ext_dll_name for extension $ext_name."
                                fi
                            else
                                log_message "WARN" "$php_ext_dll_name not found for $ext_name extension"
                            fi

                            # 拷贝其他 dll 和 ini 文件到 PHP 根目录（排除 php_*.dll）
                            local other_files_list_tmp
                            other_files_list_tmp=$(mktemp)
                            # 分别查找 dll 和 ini，确保正确排除 php_*.dll
                            find "$ext_unzip_dir" -maxdepth 1 -name '*.dll' ! -name "$php_ext_dll_name" -print0 > "$other_files_list_tmp"
                            find "$ext_unzip_dir" -maxdepth 1 -name '*.ini' -print0 >> "$other_files_list_tmp"

                            if [[ -s "$other_files_list_tmp" ]]; then
                                while IFS= read -r -d $'\0' file_path <&3; do
                                    local file_basename=$(basename "$file_path")
                                    log_message "INFO" "Copying $file_basename to $php_extract_root_dir/"
                                    if cp "$file_path" "$php_extract_root_dir/" >> "$LOG_FILE" 2>&1; then
                                        files_copied=1
                                    else
                                        log_message "ERROR" "Failed to copy $file_basename for extension $ext_name."
                                    fi
                                done 3< "$other_files_list_tmp"
                            fi
                            rm -f "$other_files_list_tmp"

                            # 对于 imagick，拷贝 config 文件夹到 PHP 根目录
                            if [[ "$ext_name" == "imagick" ]]; then
                                local config_dir="${ext_unzip_dir}/config"
                                if [[ -d "$config_dir" ]]; then
                                    log_message "INFO" "Copying config directory to $php_extract_root_dir/"
                                    if cp -r "$config_dir" "$php_extract_root_dir/" >> "$LOG_FILE" 2>&1; then
                                        files_copied=1
                                    else
                                        log_message "ERROR" "Failed to copy config directory for extension $ext_name."
                                    fi
                                else
                                    log_message "WARN" "config directory not found for imagick extension"
                                fi
                            fi

                            if [[ $files_copied -eq 0 ]]; then
                                log_message "WARN" "No files found or successfully copied for $ext_name extension from $ext_archive_filename"
                            else
                                current_ext_install_ok=1
                            fi
                        else
                            # 其他扩展保持原有处理逻辑
                            local dll_files_list_tmp # Renamed to avoid conflict
                            dll_files_list_tmp=$(mktemp)
                            # Find DLLs and store them in a temporary file
                            find "$ext_unzip_dir" -maxdepth 1 -name '*.dll' -print0 > "$dll_files_list_tmp"

                            local dll_found=0
                            # Check if any DLLs were found
                            if [[ -s "$dll_files_list_tmp" ]]; then
                                # Loop through the found DLLs from the temporary file
                                while IFS= read -r -d $'\0' dll_file <&3; do
                                    log_message "INFO" "Copying DLL: $dll_file to $php_ext_target_dir/"
                                    if cp "$dll_file" "$php_ext_target_dir/" >> "$LOG_FILE" 2>&1; then
                                        dll_found=1 # Mark as found if at least one copy succeeds for this extension
                                    else
                                        log_message "ERROR" "Failed to copy $dll_file for extension $ext_name."
                                    fi
                                done 3< "$dll_files_list_tmp"
                            fi
                            rm -f "$dll_files_list_tmp" # Clean up the temporary file

                            if [[ $dll_found -eq 0 ]]; then
                                log_message "WARN" "No DLLs found or successfully copied for extension $ext_name from $ext_archive_filename"
                                # current_ext_install_ok remains 0
                            else
                                current_ext_install_ok=1 # At least one DLL was copied
                            fi
                        fi
                    else
                        log_message "ERROR" "Failed to extract extension $ext_name from $ext_archive_path"
                        # current_ext_install_ok remains 0
                    fi
                else
                    log_message "ERROR" "Failed to download extension $ext_name from $ext_download_url"
                    # current_ext_install_ok remains 0
                fi
                # cleanup_package_temp "$ext_temp_process_dir" # Clean up individual extension temp dir

                if [[ $current_ext_install_ok -eq 1 ]]; then
                    echo "extension=${ext_name}" >> "$PHP_EXTENSIONS_STATUS_LOG_FILE"
                else
                    echo "; extension=${ext_name}" >> "$PHP_EXTENSIONS_STATUS_LOG_FILE"
                fi
            done
        fi
        fi

        # --- 3. Compress Final PHP Package ---
        if [[ $build_failed -eq 0 ]]; then
            if ! compress_directory "$php_extract_root_dir" "$final_php_package_file"; then
                build_failed=1
            fi
        fi
    fi # End of legacy PHP processing (PHP 8.0 and below)

    # --- Cleanup ---
    cleanup_package_temp "$package_temp_dir"

    if [[ $build_failed -eq 0 ]]; then
        log_message "INFO" "Successfully built PHP package $package_name $package_version for $ARCH."
        return 0
    else
        log_message "ERROR" "Failed build steps for PHP package $package_name $package_version for $ARCH."
        rm -f "$final_php_package_file" 2>/dev/null || true
        return 1
    fi
}

