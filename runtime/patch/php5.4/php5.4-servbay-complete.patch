+/* {{{ php_openssl_dh_pub_from_priv */
+static zend_bool php_openssl_dh_pub_from_priv(BIGNUM *pub_key, BIGNUM *priv_key, DH *dh)
+{
+	const BIGNUM *p;
+	BIGNUM *priv_key_const_time;
+	BN_CTX *ctx;
+	zend_bool ret = 0;
+
+	DH_get0_pqg(dh, &p, NULL, NULL);
+	if (!p) {
+		return 0;
+	}
+
+	ctx = BN_CTX_new();
+	if (!ctx) {
+		return 0;
+	}
+
+	priv_key_const_time = BN_new();
+	if (!priv_key_const_time) {
+		BN_CTX_free(ctx);
+		return 0;
+	}
+
+	if (BN_copy(priv_key_const_time, priv_key)) {
+		BN_set_flags(priv_key_const_time, BN_FLG_CONSTTIME);
+		if (BN_mod_exp_mont(pub_key, DH_get0_g(dh), priv_key_const_time, p, ctx, NULL)) {
+			ret = 1;
+		}
+	}
+
+	BN_free(priv_key_const_time);
+	BN_CTX_free(ctx);
+	return ret;
+}
+/* }}} */
+
+/* {{{ php_openssl_pkey_init_dh */
+zend_bool php_openssl_pkey_init_dh(EVP_PKEY *pkey, DH *dh, zval *data)
+{
+	BIGNUM *p, *q, *g, *priv_key, *pub_key;
+
+	OPENSSL_PKEY_SET_BN(data, p);
+	OPENSSL_PKEY_SET_BN(data, g);
+
+	if (!p || !g || !DH_set0_pqg(dh, p, NULL, g)) {
+		if (p) BN_free(p);
+		if (g) BN_free(g);
+		return 0;
+	}
+
+	OPENSSL_PKEY_SET_BN(data, priv_key);
+	OPENSSL_PKEY_SET_BN(data, pub_key);
+
+	if (priv_key) {
+		if (!pub_key) {
+			pub_key = BN_new();
+			if (!pub_key || !php_openssl_dh_pub_from_priv(pub_key, priv_key, dh)) {
+				if (pub_key) BN_free(pub_key);
+				BN_free(priv_key);
+				return 0;
+			}
+		}
+		if (!DH_set0_key(dh, pub_key, priv_key)) {
+			BN_free(pub_key);
+			BN_free(priv_key);
+			return 0;
+		}
+	} else {
+		if (pub_key) {
+			if (!DH_set0_key(dh, pub_key, NULL)) {
+				BN_free(pub_key);
+				return 0;
+			}
+		}
+		if (!DH_generate_key(dh)) {
+			return 0;
+		}
+	}
+
+	if (!EVP_PKEY_assign_DH(pkey, dh)) {
+		return 0;
+	}
+
+	return 1;
+}
