+/* {{{ php_openssl_dh_pub_from_priv */
+static zend_bool php_openssl_dh_pub_from_priv(BIGNUM *pub_key, BIGNUM *priv_key, DH *dh)
+{
+	const BIGNUM *p;
+	BIGNUM *priv_key_const_time;
+	BN_CTX *ctx;
+	zend_bool ret = 0;
+
+	DH_get0_pqg(dh, &p, NULL, NULL);
+	if (!p) {
+		return 0;
+	}
+
+	ctx = BN_CTX_new();
+	if (!ctx) {
+		return 0;
+	}
+
+	priv_key_const_time = BN_new();
+	if (!priv_key_const_time) {
+		BN_CTX_free(ctx);
+		return 0;
+	}
+
+	if (BN_copy(priv_key_const_time, priv_key)) {
+		BN_set_flags(priv_key_const_time, BN_FLG_CONSTTIME);
+		if (BN_mod_exp_mont(pub_key, DH_get0_g(dh), priv_key_const_time, p, ctx, NULL)) {
+			ret = 1;
+		}
+	}
+
+	BN_free(priv_key_const_time);
+	BN_CTX_free(ctx);
+	return ret;
+}
+/* }}} */
