            # removed from Zend/zend_portability.h and is still used by many PECL
            # extensions (phpredis/memcached/apcu/imap/imagick/...); one core patch
            # covers them all. Add more php8.6/*.patch entries here as 8.6 evolves.
            PHP_PATCHES=( "php8.6/zend_portability-xtoffsetof.patch:p0" )
            PHP_PRE_BUILD_CMDS=( "./buildconf --force" )
            PHP_MODS=( [phpredis]="6.3.0" [memcache]="8.0" [memcached]="3.2.0" [apcu]="5.1.24" [scws]="1.2.4-pre" [imagick]="3.7.0" [imap]="1.0.3" )
