###
# @description Build logic for MySQL Server.
# This is an extremely complex build with many version and architecture branches.
# @param $1 string Package version.
# @param $2 string Standardized source filename.
# @param $3 string Temporary installation directory (optional).
###
build_mysql() {
    local version=$1
    local sourceFilename=$2
    local installDir=$3
    local packageFullName="mysql-${version}"
    local version_major=$(echo "$version" | awk -F. '{print $1"."$2}')

    # 1. Determine the installation prefix.
    local prefix
    if [[ -n "$installDir" ]]; then
        prefix="$installDir"
    else
        prefix="${SERVBAY_PACKAGE_FULL_PATH}/mysql/${version_major}/${version}"
    fi
    mkdir -p "$prefix"

    # 2. Unpack source and cd into it.
    unpack_package "$packageFullName" "$sourceFilename"
    if [[ $? -ne 0 ]]; then return 1; fi

    # 3. Prepare environment and apply patches based on version/arch.
    log_message "INFO" "Preparing build environment for MySQL v${version}..."
    unset CPPFLAGS
    # Lead CFLAGS/CXXFLAGS with ONLY ServBay's OpenSSL include so the harness wins
    # over the CI runner's brew openssl@3. MySQL Router's harness_tls runs its own
    # find_package(OpenSSL) (OPENSSL_ROOT_DIR only steers the top-level one) and
    # would otherwise compile tls_*_context.cc against brew 3.x headers while
    # linking the base's OpenSSL -> undefined OSSL_DECODER_*/OSSL_PARAM_* at link.
    # cmake seeds CMAKE_C/CXX_FLAGS from this env var, and a leading -I is searched
    # before any target include dir, so the base OpenSSL headers always win.
    #
    # Do NOT also add -I${SERVBAY_COMMON_INCLUDE_PATH} here: the base ships an older
    # ICU under common/include/unicode (74 on arm64, 66 on x86_64), and a leading -I
    # makes it win over MySQL's bundled ICU 77 (WITH_ICU=bundled). gen_keyword_list
    # then compiles against icu_74/icu_66 headers but links the bundled icu_77 lib ->
    # "Undefined symbols: icu_74::UnicodeString...". Only OpenSSL needs pinning here.
    local _servbay_inc="-I${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/include"
    export CFLAGS="${_servbay_inc} -Qunused-arguments -O3 -DNDEBUG -mmacosx-version-min=${BUILD_OS_MIN_VERSION} ${BUILD_CPU_ARCH} ${BUILD_MACOS_TARGET}"
    export CXXFLAGS="${_servbay_inc} -Qunused-arguments -O3 -DNDEBUG -mmacosx-version-min=${BUILD_OS_MIN_VERSION} ${BUILD_CPU_ARCH} ${BUILD_MACOS_TARGET} -Wno-enum-constexpr-conversion"
    
    # Pre-configure steps (patches, boost, etc.)
    case "$version_major" in
        "5.1")
            export CXXFLAGS+=" -std=c++98"
            export LDFLAGS+=" -lstdc++"
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mysql/5.1/make.patch" "p0"
            if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
            ;;
        "5.5"|"5.6")
            mv VERSION MYSQL_VERSION
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mysql/${version_major}/cmake.patch" "p0"
            if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
            ;;
        "5.7")
            download_source "https://archives.boost.io/release/1.59.0/source/boost_1_59_0.tar.gz" "../boost_1_59_0.tar.gz" && tar zxf ../boost_1_59_0.tar.gz
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mysql/5.7/zlib.patch" "p0"
            if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
            ;;
        "8.0"|"8.2")
            download_source "https://archives.boost.io/release/1.77.0/source/boost_1_77_0.tar.gz" "../boost_1_77_0.tar.gz" && tar zxf ../boost_1_77_0.tar.gz
            ;;
        "8.1")
            download_source "https://archives.boost.io/release/1.77.0/source/boost_1_77_0.tar.gz" "../boost_1_77_0.tar.gz" && tar zxf ../boost_1_77_0.tar.gz
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mysql/8.1/auth.patch" "p0"
            if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
            ;;
        "8.4"|"9.0"|"9.1"|"9.2"|"9.3")
            if [[ "$architecture" == "x86_64" ]]; then
                # Assuming the patch name is consistent, e.g., x86_64-std.patch
                # Adjust filename if necessary for each version
                _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mysql/${version_major}/x86_64-std.patch" "p0"
                if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
            fi
            ;;
        "9.7")
            # Xcode 26.5 libc++ 20 dropped transitive <type_traits>; tag_plain.h
            # uses std::is_trivial_v / std::is_standard_layout_v without the
            # include. See runtime/patch/mysql/9.7/type-traits-include.patch.
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mysql/9.7/type-traits-include.patch" "p1" \
                || { cd "$SERVBAY_BUILD_DIR"; return 1; }
            ;;
    esac

    # 4. Configure and Compile.
    if [[ "$version_major" == "5.1" ]]; then
        # --- Handle ancient ./configure based build ---
        log_message "INFO" "Configuring with ./configure for MySQL 5.1..."
        ./configure \
            --prefix="${prefix}" \
            --with-unix-socket-path="${SERVBAY_TMP_PATH}/mysql-${version_major}.sock" \
            --sysconfdir="${SERVBAY_ETC_PATH}/mysql/${version_major}" \
            --with-extra-charsets=all --with-zlib-dir=bundled --with-pthread \
            --with-charset=utf8 --with-collation=utf8_general_ci --enable-local-infile \
            --with-ssl=bundled --without-embedded-server --with-comment='ServBay.dev' --without-debug
        if [[ $? -ne 0 ]]; then log_message "ERROR" "MySQL 5.1 configure failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi
        
        log_message "INFO" "Compiling and installing MySQL 5.1..."
        make -j${CPU_NUMBER} && make install
        if [[ $? -ne 0 ]]; then log_message "ERROR" "MySQL 5.1 make/install failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi
    else
        # --- Handle modern CMake based builds ---
        declare -a CMAKE_ARGS
        _get_mysql_cmake_args "$version" "$prefix"
        log_message "INFO" "Configuring with CMake for MySQL ${version_major}..."
        cmake -B builddir "${CMAKE_ARGS[@]}"
        if [[ $? -ne 0 ]]; then log_message "ERROR" "MySQL CMake configure failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi

        log_message "INFO" "Compiling and installing MySQL ${version_major}..."
        cmake --build builddir -j ${CPU_NUMBER} && cmake --install builddir
        if [[ $? -ne 0 ]]; then log_message "ERROR" "MySQL CMake build/install failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi
    fi

    # 5. Post-installation cleanup.
    log_message "INFO" "Cleaning up mysql-test directory..."
    rm -rf "${prefix}/mysql-test"

    # Return to the original build directory
    cd "$SERVBAY_BUILD_DIR"
    log_message "INFO" "MySQL build process completed successfully."
}

###
# @description Build logic for MariaDB Server.
# @param $1 string Package version.
# @param $2 string Standardized source filename.
# @param $3 string Temporary installation directory (optional).
###
build_mariadb() {
    local version=$1
    local sourceFilename=$2
    local installDir=$3
    local packageFullName="mariadb-${version}"
    local version_major=$(echo "$version" | awk -F. '{print $1"."$2}')

    # 1. Determine the installation prefix.
    local prefix
    if [[ -n "$installDir" ]]; then
        prefix="$installDir"
    else
        prefix="${SERVBAY_PACKAGE_FULL_PATH}/mariadb/${version_major}/${version}"
    fi
    mkdir -p "$prefix"

    # 2. Unpack source and cd into it.
    unpack_package "$packageFullName" "$sourceFilename"
    if [[ $? -ne 0 ]]; then return 1; fi

    # 3. Apply version-specific patches using the new, precise helper.
    local patch_versions_no_o_direct=("11.4.0" "11.4.1" "11.5.0" "11.3.2" "11.2.3" "11.1.4" "11.0.5" "10.11.7")
    if [[ " ${patch_versions_no_o_direct[@]} " =~ " ${version} " ]]; then
        _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mariadb/os_data_file_no_o_direct.patch" "p1"
        if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
    fi

    local patch_versions_innodb_crash=("10.11.8" "11.0.6" "11.1.5" "11.2.4" "11.4.2" "11.5.1" "11.6.0")
    if [[ " ${patch_versions_innodb_crash[@]} " =~ " ${version} " ]]; then
        _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mariadb/innodb_crash.patch" "p1"
        if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
        _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mariadb/mariadb-install-db_hang.patch" "p1"
        if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
    fi

    # groonga's cmake misdetects <netdb.h> on x86_64 (every feature probe fails),
    # leaving struct addrinfo incomplete and breaking mroonga. Force-include
    # netdb.h on ALL x86_64 builds — the old per-version whitelist went stale on
    # every MariaDB release (e.g. 11.8.8 was missing). Non-fatal: patch -N skips
    # an already-patched tree, and a context mismatch on a differently-vendored
    # groonga must warn rather than block the build.
    if [[ "$architecture" == "x86_64" ]]; then
        _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/mariadb/fix-groonga-netdb-11.4-x86_64.patch" "p0" \
            || log_message "WARN" "groonga-netdb x86_64 patch not applied for ${version} (already patched or vendored groonga differs)"
    fi

    # 4. Configure with CMake.
    log_message "INFO" "Configuring MariaDB v${version} with CMake..."
    local cmake_args=(
        "-DCMAKE_INSTALL_PREFIX=${prefix}"
        "-DMYSQL_DATADIR=${SERVBAY_DB_PATH}/mariadb/${version_major}"
        "-DMYSQL_UNIX_ADDR=${SERVBAY_TMP_PATH}/mariadb-${version_major}.sock"
        "-DDEFAULT_SYSCONFDIR=${SERVBAY_ETC_PATH}/mariadb/${version_major}"
        "-DEXTRA_CHARSETS=all"
        "-DDEFAULT_CHARSET=utf8mb4"
        "-DDEFAULT_COLLATION=utf8mb4_general_ci"
        "-DENABLED_LOCAL_INFILE=1"
        "-DPLUGIN_TOKUDB=NO"
        "-DPLUGIN_ROCKSDB=NO"
        # Disable ODBC in the CONNECT engine. On x86_64 cmake finds the CI runner's
        # brew unixODBC (/usr/local/opt/unixodbc) and ha_connect.so links it, which
        # would not load on a user machine without Homebrew. arm64 already ships
        # CONNECT without ODBC (no unixODBC on that runner), so this aligns both.
        "-DCONNECT_WITH_ODBC=OFF"
        "-DWITH_READLINE=NO"
        "-DWITH_UNIT_TESTS=OFF"
        "-DWITH_SSL=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}"
        "-DWITH_LZ4=${SERVBAY_COMMON_PATH}"
        "-DWITH_ZSTD=bundled"
        "-DWITH_ZLIB=${SERVBAY_COMMON_PATH}"
        "-DWITH_PCRE=bundled"
        "-DWITH_BISON=${SERVBAY_COMMON_PATH}"
        "-DWITH_JEMALLOC=${SERVBAY_COMMON_PATH}"
        "-DWITH_EMBEDDED_SERVER=1"
        "-DWITH_DEBUG=0"
        "-DWITH_BIG_TABLES=1"
        "-DBoost_NO_BOOST_CMAKE=ON"
        "-DCMAKE_MACOSX_RPATH=1"
        "-DCURSES_INCLUDE_PATH=${SERVBAY_COMMON_INCLUDE_PATH}/ncursesw"
        "-DCMAKE_PREFIX_PATH=\"${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/include;${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/lib;${SERVBAY_COMMON_LIB_PATH}/ncursesw;${SERVBAY_COMMON_INCLUDE_PATH}/ncursesw;${SERVBAY_COMMON_LIB_PATH};${SERVBAY_COMMON_INCLUDE_PATH};${SERVBAY_BIN_PATH}\""
        "-DCMAKE_OSX_DEPLOYMENT_TARGET=${BUILD_OS_MIN_VERSION}"
        "-DCMAKE_OSX_ARCHITECTURES=$(echo "$BUILD_CPU_ARCH" | awk '{print $2}')"
        "-DCOMPILATION_COMMENT='ServBay.dev'"
    )
    cmake -B builddir "${cmake_args[@]}"
    if [[ $? -ne 0 ]]; then log_message "ERROR" "MariaDB CMake configure failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi

    # 5. Compile and Install.
    log_message "INFO" "Compiling and installing MariaDB..."
    cmake --build builddir -j ${CPU_NUMBER} && cmake --install builddir
    if [[ $? -ne 0 ]]; then log_message "ERROR" "MariaDB CMake build/install failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi

    # 6. Post-installation cleanup.
    log_message "INFO" "Cleaning up test suites and static libraries..."
    rm -rf "${prefix}/mysql-test"
    rm -rf "${prefix}/mariadb-test"
    rm -rf "${prefix}/sql-bench"
    rm -f "${prefix}/lib/"*.a

    # Return to the original build directory
    cd "$SERVBAY_BUILD_DIR"
    log_message "INFO" "MariaDB build process completed successfully."
}

###
# @description Build logic for PostgreSQL and its extensions.
# @param $1 string Package version.
# @param $2 string Standardized source filename.
# @param $3 string Temporary installation directory (optional).
###
build_postgresql() {
    local version=$1
    local sourceFilename=$2
    local installDir=$3
    local packageFullName="postgresql-${version}"
    
    # Handle versions like "16rc1", "19beta2", "20alpha1" to get major "16", "19", "20"
    local version_major=${version%%.*}
    version_major=${version_major%%rc*}
    version_major=${version_major%%beta*}
    version_major=${version_major%%alpha*}

    # 1. Define the module configuration for this PostgreSQL version.
    # This is the "module configuration center".
    # To add a new module, just add a line here and create its _build_... function.
    PGSQL_MODS=() # Clear the global array first
    PGSQL_MODS=(
        [postgis]="3.4.4"
        [pgrouting]="3.8.0"
        [pgvector]="0.8.5"
        [pg_jieba]="1.1.1"
        [zhparser]="2.3"
    )
    # Example for future version-specific modules:
    if [[ "$version_major" -ge 18 ]]; then
        # postgis 3.5.7 wraps its static composite_to_json copy in
        # #if POSTGIS_PGSQL_VERSION < 190 -- PG 19 exposes composite_to_json
        # as extern in server/utils/json.h, so postgis 3.5.4's unconditional
        # static copy collides ("static declaration follows non-static").
        # The postgis-limits-h.patch still applies (context unchanged).
        PGSQL_MODS[postgis]="3.5.7"
    fi

    # 2. Determine the installation prefix.
    local prefix
    if [[ -n "$installDir" ]]; then
        prefix="$installDir"
    else
        prefix="${SERVBAY_PACKAGE_FULL_PATH}/postgresql/${version_major}/${version}"
    fi
    mkdir -p "$prefix"

    # 3. Unpack PostgreSQL source and cd into it.
    unpack_package "$packageFullName" "$sourceFilename"
    if [[ $? -ne 0 ]]; then return 1; fi

    # 4. Apply version and architecture specific patches.
    integer version_major_num=$version_major
    if [[ "$architecture" == "arm64" ]]; then
        if (( version_major_num <= 10 )); then
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/pgsql/icu-pg10.patch" "p0" && \
            _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/pgsql/icu68.patch" "p1"
            if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi
        fi
    fi
    # Common patch for both architectures
    _apply_single_patch "${SERVBAY_BUILD_DIR}/patch/pgsql/tmpdir.patch" "p0"
    if [[ $? -ne 0 ]]; then cd "$SERVBAY_BUILD_DIR"; return 1; fi

    # 5. Configure PostgreSQL.
    log_message "INFO" "Configuring PostgreSQL v${version}..."
    local extra_cflags=""
    if (( version_major_num <= 9 )); then
        extra_cflags="CFLAGS=-Wno-error=implicit-function-declaration"
    fi
    
    # Use eval to correctly handle the extra CFLAGS string if it exists
    eval ./configure \
        --prefix="${prefix}" \
        --with-includes="${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}" \
        --with-libraries="${SERVBAY_COMMON_LIB_PATH}" \
        --enable-thread-safety --with-gssapi --with-icu --with-ldap \
        --with-libxml --with-libxslt --with-lz4 --with-openssl --with-pam \
        --with-bonjour --with-zstd --with-libedit-preferred --with-uuid=e2fs \
        "--with-extra-version=\(ServBay\)" \
        PG_SYSROOT=/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/ \
        $extra_cflags
    if [[ $? -ne 0 ]]; then log_message "ERROR" "PostgreSQL configure failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi

    # 6. Compile and install PostgreSQL.
    log_message "INFO" "Compiling PostgreSQL..."
    make -j${CPU_NUMBER}
    if [[ $? -ne 0 ]]; then log_message "ERROR" "PostgreSQL make failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi

    # install-world-bin installs core + contrib but SKIPS docs. The CI runner has
    # no docbook/xsltproc toolchain, so the old `install-world` failed building
    # postgres-full.xml. ServBay ships the server + extensions, not the HTML/man
    # manual, so dropping docs is intentional.
    log_message "INFO" "Installing PostgreSQL (make install-world-bin, docs skipped)..."
    make install-world-bin
    if [[ $? -ne 0 ]]; then log_message "ERROR" "PostgreSQL make install-world-bin failed."; cd "$SERVBAY_BUILD_DIR"; return 1; fi

    # 7. Build all configured modules.
    log_message "INFO" "Building PostgreSQL extensions..."
    local pgsql_module_failed=false
    for mod_name mod_version in ${(kv)PGSQL_MODS}; do
        local mod_build_func="_build_pgsql_mod_${mod_name//-/_}"
        if whence -f "$mod_build_func" > /dev/null; then
            "$mod_build_func" "$mod_version" "$version" "$version_major" "$prefix"
            if [[ $? -ne 0 ]]; then
                log_message "ERROR" "Failed to build PostgreSQL module: ${mod_name} v${mod_version}"
                pgsql_module_failed=true
            fi
        else
            log_message "WARN" "Build function ${mod_build_func} not found for module ${mod_name}."
        fi
    done

    if [[ "$pgsql_module_failed" == "true" ]]; then
        log_message "ERROR" "One or more PostgreSQL modules failed to build. Aborting packaging."
        cd "$SERVBAY_BUILD_DIR"
        return 1
    fi

    # 8. Post-installation tasks.
    if [[ -z "$installDir" ]]; then
        log_message "INFO" "Performing post-installation tasks..."
        local libpq_copy_version="16" # Default for x86
        if [[ "$architecture" == "arm64" ]]; then
            libpq_copy_version="16"
        fi
        if [[ "$version_major" == "$libpq_copy_version" ]]; then
            log_message "INFO" "Copying libpq for PHP compatibility..."
            cp -P "${prefix}/lib/libpq"*".dylib" "${SERVBAY_COMMON_LIB_PATH}"
            install_name_tool -id "${SERVBAY_COMMON_LIB_PATH}/libpq.5.dylib" "${SERVBAY_COMMON_LIB_PATH}/libpq.5.dylib"
        fi
    fi

    # Return to the original build directory
    cd "$SERVBAY_BUILD_DIR"
    log_message "INFO" "PostgreSQL and extensions build process completed successfully."
}

