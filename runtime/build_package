###
# @description Main dispatcher for all package builds.
# @param $1 - $4 All necessary build parameters.
###
build_package() {
    local packageName=$1
    local version=$2
    local sourceFilename=$3
    local installDir=$4

    # 步骤 1: 获取一次 SDK 路径并存为变量
    export SDK_PATH=$(xcrun --sdk macosx --show-sdk-path)

    # 步骤 2: 将 SDK 路径设置给 CMAKE_OSX_SYSROOT (用于 CMake 项目)
    export CMAKE_OSX_SYSROOT="${SDK_PATH}"

    # 步骤 3: 将 -isysroot 标志添加到 CFLAGS, LDFLAGS, 和 CXXFLAGS (用于非 CMake 项目)
    # 注意：我们在原有内容的【前面】加入了 -isysroot 标志
    export CFLAGS="-isysroot ${SDK_PATH} -Qunused-arguments -O3 -mmacosx-version-min=${BUILD_OS_MIN_VERSION} ${BUILD_CPU_ARCH} ${BUILD_MACOS_TARGET}"
    export LDFLAGS="-isysroot ${SDK_PATH} -Wl,-rpath -Wl,${SERVBAY_COMMON_LIB_PATH} -L${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/lib -L${SERVBAY_COMMON_LIB_PATH} -L${SERVBAY_PACKAGE_FULL_PATH} -mmacosx-version-min=${BUILD_OS_MIN_VERSION} ${BUILD_CPU_ARCH} ${BUILD_MACOS_TARGET}"
    export CPPFLAGS="-I${SERVBAY_COMMON_INCLUDE_PATH} -I${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/include"
    export CXXFLAGS="-isysroot ${SDK_PATH} -Qunused-arguments -O3 -mmacosx-version-min=${BUILD_OS_MIN_VERSION} ${BUILD_CPU_ARCH} ${BUILD_MACOS_TARGET} -Wno-enum-constexpr-conversion"

    # 其他环境变量设置
    export PKG_CONFIG_PATH="${SERVBAY_COMMON_LIB_PATH}/pkgconfig:${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/lib/pkgconfig"
    export PKG_CONFIG="${SERVBAY_BIN_PATH}/pkg-config"
    export PKG_CONFIG_LIBDIR="${SERVBAY_COMMON_LIB_PATH}/pkgconfig:${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}/lib/pkgconfig"
    export PATH="${SERVBAY_BIN_PATH}:${SERVBAY_SBIN_PATH}:/usr/bin:/bin:/usr/sbin:/sbin:/Library/Apple/usr/bin:/usr/local/bin:/usr/local/sbin:/opt/homebrew/bin"

    if ! command -v go &> /dev/null; then
        log_message "WARN" "Warning: 'go' command not found. Go-based packages will fail to build."
    else
        if [[ -z "$GOPATH" ]]; then
            export GOPATH="$HOME/go"
        fi
        # Add GOPATH/bin to PATH for Go tools like tscriptify
        export PATH="${GOPATH}/bin:${PATH}"
        export GO111MODULE=on
        export GOPROXY=https://proxy.golang.org,direct
        "$GO_BIN" env -w GO111MODULE=on &>/dev/null
        "$GO_BIN" env -w GOPROXY=https://proxy.golang.org,direct &>/dev/null
    fi

    local build_function_name="build_${packageName//-/_}"
    if whence -f "$build_function_name" > /dev/null; then
        "$build_function_name" "$version" "$sourceFilename" "$installDir"
    else
        log_message "ERROR" "❓ Build function '$build_function_name' not implemented."
        return 1
    fi
}


###
# @description Set up the build environment by ensuring /Applications/ServBay is the v1 environment.
# Safety: Strictly relies on the presence of 'package' (v1) and 'packages' (v2) markers.
###
setup_build_env() {
    log_message "INFO" "🔄 Setting up build environment for v1..."
    
    # 1. Check current occupants in /Applications/ServBay
    if [[ -d "/Applications/ServBay" ]]; then
        if [[ -d "/Applications/ServBay/package" ]]; then
            log_message "INFO" "✅ v1 environment is already active at /Applications/ServBay"
            return 0
        elif [[ -d "/Applications/ServBay/packages" ]]; then
            log_message "WARN" "⚠️ Detected v2 environment (packages directory) at /Applications/ServBay."
            if [[ -e "/Applications/ServBay-2.0" ]]; then
                log_message "ERROR" "❌ Fatal: Cannot move v2 environment to /Applications/ServBay-2.0 because it already exists. Manual intervention required."
                exit 1
            else
                log_message "INFO" "📦 Safely storing v2 environment to /Applications/ServBay-2.0"
                mv "/Applications/ServBay" "/Applications/ServBay-2.0"
            fi
        else
            log_message "ERROR" "❌ Fatal: /Applications/ServBay exists but contains neither 'package' (v1) nor 'packages' (v2) markers. Manual intervention required to prevent data loss."
            exit 1
        fi
    fi

    # 2. Activate v1 environment from storage if needed and target is empty
    if [[ ! -e "/Applications/ServBay" ]]; then
        if [[ -d "/Applications/ServBay-1.0" ]]; then
            if [[ -d "/Applications/ServBay-1.0/package" ]]; then
                log_message "INFO" "📦 Activating v1 environment from /Applications/ServBay-1.0 to /Applications/ServBay"
                mv "/Applications/ServBay-1.0" "/Applications/ServBay"
            else
                log_message "ERROR" "❌ Fatal: /Applications/ServBay-1.0 exists but lacks the explicit v1 'package' marker. Refusing to activate. Manual intervention required."
                exit 1
            fi
        else
            log_message "INFO" "ℹ️ No existing v1 environment found at /Applications/ServBay-1.0. A new one will be created at /Applications/ServBay."
        fi
    fi
}

###
# @description Tear down the build environment by safely moving /Applications/ServBay back to /Applications/ServBay-1.0.
###
teardown_build_env() {
    log_message "INFO" "🔄 Tearing down build environment for v1..."
    
    if [[ -d "/Applications/ServBay" ]]; then
        if [[ -d "/Applications/ServBay/package" ]]; then
            if [[ -e "/Applications/ServBay-1.0" ]]; then
                log_message "ERROR" "❌ Error during teardown: /Applications/ServBay-1.0 already exists. Cannot store current v1 environment. Leaving at /Applications/ServBay."
            else
                log_message "INFO" "📦 Storing v1 environment from /Applications/ServBay to /Applications/ServBay-1.0"
                mv "/Applications/ServBay" "/Applications/ServBay-1.0"
            fi
        elif [[ -d "/Applications/ServBay/packages" ]]; then
            log_message "ERROR" "❌ Fatal Error during teardown: v1 script is exiting, but /Applications/ServBay contains v2 markers ('packages'). Refusing to store as v1."
        else
            log_message "ERROR" "❌ Error during teardown: /Applications/ServBay does not contain v1 markers. Leaving as is."
        fi
    else
        log_message "INFO" "ℹ️ Nothing to tear down (no /Applications/ServBay found)."
    fi
}

# Trap exits to ensure the environment is always torn down
trap teardown_build_env EXIT INT TERM HUP

init_logging

setup_build_env

log_message "INFO" "==================== Build Script Started ===================="
log_message "INFO" "Using Zsh shell for execution."

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -p|--package)
            # 支持逗号分隔和空格分隔: -p pkg1,pkg2 或 -p pkg1 pkg2
            packageNames="$2"; shift
            while [[ "$#" -gt 1 && ! "$2" =~ ^- ]]; do
                packageNames="${packageNames},${2}"; shift
            done
            ;;
        -a|--architecture) architecture="$2"; shift ;;
        --install-dir) installDir="$2"; shift ;;
        -h|--help) usage ;;
        *) log_message "ERROR" "Unknown parameter passed: $1"; usage ;;
    esac
    shift
done

if [[ -z "$architecture" ]]; then
    log_message "ERROR" "Architecture is required."
    usage
fi
if [[ "$architecture" != "x86_64" ]] && [[ "$architecture" != "arm64" ]]; then
    log_message "ERROR" "Invalid architecture."
    usage
fi

if [[ "$architecture" == "x86_64" ]]; then
    BUILD_CPU_ARCH="-arch x86_64"
    BUILD_MACOS_TARGET="-target x86_64-apple-macos${BUILD_OS_MIN_VERSION}"
    OPENSSL_VERSION="1.1.1u"
else
    BUILD_CPU_ARCH="-arch arm64"
fi

log_message "INFO" "Executing in: $(pwd)"
log_message "INFO" "Target Architecture: $architecture"
log_message "INFO" "OpenSSL Version: $OPENSSL_VERSION"

if [[ -z "$packageNames" ]]; then
    # --- Batch Mode ---
    log_message "INFO" "Running in Batch Mode from packages.conf"
    if [[ ! -f "packages.conf" ]]; then
        log_message "ERROR" "packages.conf not found."
        exit 1
    fi

    while IFS= read -r packageLine || [[ -n "$packageLine" ]]; do
        if [[ $packageLine == \#* ]] || [[ -z "$packageLine" ]]; then
            continue
        fi

        read -r PackageName Version x86_64_Filename arm64_Filename <<< "$packageLine"
        
        sourceFilename=$([[ "$architecture" == "x86_64" ]] && echo "$x86_64_Filename" || echo "$arm64_Filename")

        if [[ "$sourceFilename" == "-" ]]; then
            log_message "WARN" "Skipping $PackageName-$Version for $architecture (not available)."
            continue
        fi
        
        ext=$(get_extension "$sourceFilename" "$PackageName")
        if [[ $? -ne 0 ]]; then
            continue
        fi
        standardFilename="$PackageName-$Version.$ext"
        packageFullName="$PackageName-$Version"

        log_message "INFO" "----------------- Processing ${packageFullName} -----------------"
        
        downloadUrl=$(get_download_url "$PackageName" "$Version" "$sourceFilename")
        if ! download_source "$downloadUrl" "${SERVBAY_BUILD_SRC_DIR}/${standardFilename}"; then
            log_message "ERROR" "Download failed for ${PackageName}. Skipping."
            continue
        fi

        if ! build_package "$PackageName" "$Version" "$standardFilename" "$installDir"; then
             log_message "ERROR" "❌❌❌ Build failed for ${packageFullName}. Skipping post-build process. ❌❌❌"
             continue
        fi

        if ! post_build_process "$PackageName" "$Version"; then
            log_message "ERROR" "‼️ Post-build process failed for ${packageFullName}."
        else
            cleanup_source_directory "$packageFullName"
        fi
        log_message "INFO" "----------------- Finished ${packageFullName} -----------------\n"

    done < packages.conf

    # Show error summary if there were failures
    if [[ -f "$ERROR_FILE" ]] && [[ -s "$ERROR_FILE" ]]; then
        log_message "WARN" "⚠️ Some packages failed to build. See errors in: $ERROR_FILE"
        echo "=== Failed Packages ===" >&2
        grep -oE 'Build failed for [a-zA-Z0-9_.-]+' "$ERROR_FILE" | sed 's/\.$//' | sort -u | while read -r line; do
            echo "  ❌ ${line#Build failed for }" >&2
        done
        grep -oE 'Failed to build PHP module: [a-zA-Z0-9_.-]+ v[a-zA-Z0-9_.-]+' "$ERROR_FILE" | sort -u | while read -r line; do
            echo "  ❌ PHP module: ${line#Failed to build PHP module: }" >&2
        done
        echo "======================" >&2
    fi

else
    # --- Multiple/Single Package Mode ---
    # Split packageNames by comma
    IFS=',' read -A packageList <<< "$packageNames"

    # Count packages
    local packageCount=${#packageList[@]}
    if [[ $packageCount -eq 1 ]]; then
        log_message "INFO" "Running in Single Package Mode for ${packageList[1]}"
    else
        log_message "INFO" "Running in Multiple Package Mode for $packageCount packages"
    fi

    # Track failed packages
    local failedPackages=()
    local successCount=0

    # Process each package
    for packageName in "${packageList[@]}"; do
        # Trim whitespace
        packageName="${packageName// /}"

        if [[ -z "$packageName" ]]; then
            continue
        fi

        if [[ $packageName != *-* ]]; then
            log_message "ERROR" "Invalid package format: $packageName (expected format: name-version)"
            failedPackages+=("$packageName")
            continue
        fi

        # Try to find the correct split point for package name and version
        # by testing all possible splits against packages.conf
        packageLine=""
        PackageName=""
        Version=""

        # Split the packageName by '-' and try different combinations
        local parts=("${(@s:-:)packageName}")  # Split by '-' into array
        local numParts=${#parts[@]}

        # Try splitting at each possible position (from left to right)
        for ((i=1; i<numParts; i++)); do
            local testPackageName="${(j:-:)parts[1,$i]}"  # Join first i parts with '-'
            local testVersion="${(j:-:)parts[$((i+1)),$numParts]}"  # Join remaining parts with '-'

            local testLine=$(grep -E "^${testPackageName}\s+${testVersion}\s" packages.conf)
            if [[ -n "$testLine" ]]; then
                PackageName="$testPackageName"
                Version="$testVersion"
                packageLine="$testLine"
                read -r _ _ x86_64_Filename arm64_Filename <<< "$packageLine"
                break
            fi
        done

        # Fallback: no exact "<name> <version>" line in packages.conf. Reuse the same
        # package's newest line (active OR commented) as a TEMPLATE and substitute its
        # version into the filename columns. This keeps the filename format intact, so
        # binary packages (e.g. node-v<ver>-darwin-arch.tar.gz) also resolve correctly,
        # and lets you build a one-off newer version without first editing packages.conf.
        if [[ -z "$packageLine" ]]; then
            for ((i=1; i<numParts; i++)); do
                local testPackageName="${(j:-:)parts[1,$i]}"
                local testVersion="${(j:-:)parts[$((i+1)),$numParts]}"
                # Pick the newest line of this package whose version ACTUALLY appears in
                # its filename, so the substitution is meaningful. This skips dev/snapshot
                # rows whose file is a commit hash (e.g. php 8.6.0-dev), where the version
                # string is absent and replacement would be a no-op.
                local _tn _tv _tx _ta tmplFound=""
                while IFS= read -r tmplLine; do
                    read -r _tn _tv _tx _ta <<< "${tmplLine#\#}"
                    [[ -n "$_tv" && "$_tx" == *"$_tv"* ]] && tmplFound="${tmplLine#\#}"
                done < <(grep -E "^#?[[:space:]]*${testPackageName}[[:space:]]" packages.conf)
                if [[ -n "$tmplFound" ]]; then
                    read -r _tn _tv _tx _ta <<< "$tmplFound"
                    PackageName="$testPackageName"
                    Version="$testVersion"
                    x86_64_Filename="${_tx//$_tv/$Version}"
                    arm64_Filename="${_ta//$_tv/$Version}"
                    packageLine="template"
                    log_message "WARN" "⚠️ ${packageName} not in packages.conf; using '${_tn} ${_tv}' as template → version ${Version} (${x86_64_Filename} / ${arm64_Filename})"
                    break
                fi
            done
        fi

        packageFullName="$packageName"

        if [[ -z "$packageLine" ]]; then
            log_message "ERROR" "❓ Package $packageName not found in packages.conf (and no same-package template to substitute)"
            failedPackages+=("$packageName")
            continue
        fi

        sourceFilename=$([[ "$architecture" == "x86_64" ]] && echo "$x86_64_Filename" || echo "$arm64_Filename")

        if [[ "$sourceFilename" == "-" ]]; then
            log_message "ERROR" "❓ Package $packageName not available for $architecture"
            failedPackages+=("$packageName")
            continue
        fi

        ext=$(get_extension "$sourceFilename" "$PackageName")
        if [[ $? -ne 0 ]]; then
            failedPackages+=("$packageName")
            continue
        fi
        standardFilename="$PackageName-$Version.$ext"

        log_message "INFO" "----------------- Processing ${packageFullName} -----------------"

        downloadUrl=$(get_download_url "$PackageName" "$Version" "$sourceFilename")
        if ! download_source "$downloadUrl" "${SERVBAY_BUILD_SRC_DIR}/${standardFilename}"; then
            log_message "ERROR" "Download failed for ${packageName}. Skipping."
            failedPackages+=("$packageName")
            continue
        fi

        if build_package "$PackageName" "$Version" "$standardFilename" "$installDir"; then
            if post_build_process "$PackageName" "$Version"; then
                cleanup_source_directory "$packageFullName"
                successCount=$((successCount + 1))
                log_message "INFO" "✅ Successfully built ${packageFullName}"
            else
                log_message "ERROR" "‼️ Post-build process failed for ${packageName}."
                failedPackages+=("$packageName")
            fi
        else
            log_message "ERROR" "❌❌❌ Build failed for ${packageName}. ❌❌❌"
            failedPackages+=("$packageName")
        fi
        log_message "INFO" "----------------- Finished ${packageFullName} -----------------\n"
    done

    # Summary
    log_message "INFO" "============== Build Summary =============="
    log_message "INFO" "Total packages: $packageCount"
    log_message "INFO" "Successful: $successCount"
    log_message "INFO" "Failed: ${#failedPackages[@]}"

    if [[ ${#failedPackages[@]} -gt 0 ]]; then
        log_message "ERROR" "Failed packages: ${(j:, :)failedPackages}"
        exit 1
    fi
fi

log_message "INFO" "==================== Build Script Finished ===================="
