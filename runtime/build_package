###
# @description "Knowledge Base" for package verification.
# @param $1 string Package name.
# @param $2 string Package version.
# @stdout The verification command string.
###
get_package_verification_info() {
    local packageName="$1"
    local packageVersion="$2"
    local verify_command=""

    case "$packageName" in
        "redis")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/bin/redis-server -v"
            ;;
        "memcached")
            # Memcached uses -V (uppercase) for version
            verify_command="${SERVBAY_BIN_PATH}/memcached -V"
            ;;
        "caddy")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/bin/caddy version"
            ;;
        "nginx")
            # Note: Nginx installs into a versioned subdirectory within the prefix
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/nginx/${packageVersion}/sbin/nginx -v"
            ;;
        "httpd")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/apache/${version_major}/${packageVersion}/sbin/httpd -v"
            ;;
        "php")
            local package_version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/php/${package_version_major}/${packageVersion}/bin/php -v"
            ;;
        "dnsmasq")
            # Dnsmasq uses -v (lowercase) for version
            verify_command="${SERVBAY_SBIN_PATH}/dnsmasq -v"
            ;;
        "subversion")
            verify_command="${SERVBAY_BIN_PATH}/svn --version"
            ;;
        "git")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/git/bin/git --version"
            ;;
        "cloudflared")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/cloudflared/bin/cloudflared -v"
            ;;
        "frp")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/frp/bin/frpc -v"
            ;;
        "ngrok")
            # ngrok version output is like "ngrok version 3.x.x"
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/ngrok/bin/ngrok -v"
            ;;
        "pinggy")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/pinggy/bin/pinggy --version"
            ;;
        "mailpit")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/mailpit/bin/mailpit version | grep -i 'compiled with'"
            ;;
        "ai-gateway")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/ai-gateway/bin/servbay-ai-gateway --version"
            ;;
        "disk-cleaner")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/disk-cleaner/bin/servbay-diskcleaner --version"
            ;;
        "mongosh")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/mongosh/2.0/bin/mongosh --version"
            ;;
        "mongotools")
            # Use mongostat for version check as in the original script
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/mongotools/bin/mongostat --version"
            ;;
        "mongodb")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/mongodb/${version_major}/${packageVersion}/bin/mongod --version"
            ;;
        "ollama")
            local ollama_major=${packageVersion%%.*}
            local ollama_version_remainder=${packageVersion#*.}
            local ollama_minor=${ollama_version_remainder%%.*}
            if [[ "$ollama_major" == <-> && "$ollama_minor" == <-> ]] &&
               (( ollama_major > 0 || (ollama_major == 0 && ollama_minor >= 30) )); then
                verify_command="test -x ${SERVBAY_PACKAGE_FULL_PATH}/ollama/lib/ollama/llama-server && test -x ${SERVBAY_PACKAGE_FULL_PATH}/ollama/lib/ollama/llama-quantize && ${SERVBAY_PACKAGE_FULL_PATH}/ollama/lib/ollama/llama-server --version >/dev/null && ${SERVBAY_PACKAGE_FULL_PATH}/ollama/ollama -v"
            else
                verify_command="${SERVBAY_PACKAGE_FULL_PATH}/ollama/ollama -v"
            fi
            ;;
        "minio")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/minio/bin/minio -v"
            ;;
        "typesense")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/typesense/bin/typesense-server --version 2>&1 | grep ${packageVersion}"
            ;;
        "meilisearch")
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/meilisearch/bin/meilisearch --version"
            ;;
        "composer")
            # Composer 2.2 LTS 支持 PHP 5.3-7.1，使用 PHP 7.4 验证
            # Composer 2.x latest 支持 PHP 7.2+，使用 PHP 8.4 验证
            local composer_bin
            if [[ "$packageVersion" == 2.2.* ]]; then
                composer_bin="composer-2.2"
            else
                composer_bin="composer"
            fi
            # composer.phar embeds its version (const VERSION = '<ver>'). grep it
            # instead of running `php composer --version`: the CI build base has no
            # php runtime to execute the phar, which used to fail this step.
            verify_command="grep -a ${packageVersion} ${SERVBAY_BIN_PATH}/${composer_bin}"
            ;;
