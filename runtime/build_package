            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            local mono_path="${SERVBAY_PACKAGE_FULL_PATH}/mono/${version_major}/${packageVersion}"
            # We need to verify both mono and xsp
            local mono_check="${mono_path}/bin/mono -V 2>&1 | grep -q ${packageVersion}"
            local xsp_check="${mono_path}/bin/xsp4 --version 2>&1 | grep -q 0.4.0.0"
            verify_command="${mono_check} && ${xsp_check}"
            ;;
        "ruby")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/ruby/${version_major}/${packageVersion}/bin/ruby -v"
            ;;
        "python")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            # Use pythonX.Y -V to get the version
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/python/${version_major}/${packageVersion}/bin/python${version_major} -V"
            ;;
        "node")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/node/${version_major}/${packageVersion}/bin/node -v"
            ;;
        "deno")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/deno/${version_major}/${packageVersion}/deno --version"
            ;;
        "bun")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/bun/${version_major}/${packageVersion}/bun --version"
            ;;
        "mysql")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            # Use mysql client -V for version
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/mysql/${version_major}/${packageVersion}/bin/mysql -V"
            ;;
        "mariadb")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/mariadb/${version_major}/${packageVersion}/bin/mariadb -V"
            ;;
        "postgresql")
            local version_major=${packageVersion%%.*}
            version_major=${version_major%%rc*}
            version_major=${version_major%%beta*}
            version_major=${version_major%%alpha*}
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/postgresql/${version_major}/${packageVersion}/bin/psql -V"
            ;;
        "php")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            local php_bin="${SERVBAY_PACKAGE_FULL_PATH}/php/${version_major}/${packageVersion}/bin/php"
            # Special handling for dev version verification string
            if [[ "$packageVersion" =~ -dev$ || "$packageVersion" =~ -alpha.*$ || "$packageVersion" =~ -beta.*$ || "$packageVersion" =~ -rc.*$ ]]; then
                local version_to_grep=${packageVersion%-*} # e.g., 8.5.0 from 8.5.0-dev
                verify_command="${php_bin} -v 2>&1 | grep -q ${version_to_grep}"
            else
                verify_command="${php_bin} -v 2>&1 | grep -q ${packageVersion}"
            fi
            ;;
        *)
            log_message "ERROR" "No verification rule for package '$packageName'."
            return 1
            ;;
    esac
    
    echo "$verify_command"
    return 0
}

