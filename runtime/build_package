            local version_major=$(echo "$packageVersion" | awk -F. '{print $1"."$2}')
            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/go/${version_major}/${packageVersion}/bin/go version"
            ;;
        "openjdk")
