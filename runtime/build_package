    log_message "INFO" "Installing Git ${version}..."
    make install NO_RUST=1
    if [[ $? -ne 0 ]]; then
        log_message "ERROR" "Git 'make install' failed."
        cd "$SERVBAY_BUILD_DIR"
        return 1
    fi

    cd "$SERVBAY_BUILD_DIR"
    log_message "INFO" "Git build process completed successfully."
}

