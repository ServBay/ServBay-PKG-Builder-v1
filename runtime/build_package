###
# @description Internal helper to apply a single, specific patch file.
# @param $1 string Full path to the .patch file.
# @param $2 string The patch level to use (e.g., "p0", "p1").
###
_apply_single_patch() {
    local patch_file=$1
    local patch_level=$2

    if [[ -f "$patch_file" ]]; then
        log_message "INFO" "Applying patch: $(basename "$patch_file") with level ${patch_level}..."
        patch --ignore-whitespace -N "-${patch_level}" < "$patch_file"
        if [[ $? -ne 0 ]]; then
            log_message "ERROR" "Failed to apply patch: $(basename "$patch_file")"
            # Returning a non-zero status allows the calling function to handle the error
            return 1
        fi
    else
        log_message "ERROR" "Patch file not found: ${patch_file}"
        return 1
    fi
    return 0
}

###
# @description Internal helper to apply all patch files from a given directory.
# @param $1 string Directory containing .patch files.
# @param $2 string The patch level to use (e.g., "p0", "p1").
###
_apply_patches() {
    local patch_dir=$1
    local patch_level=$2
    if [[ -d "$patch_dir" ]]; then
        log_message "INFO" "Applying patches from ${patch_dir} with level ${patch_level}..."
        for file in "${patch_dir}"/*.patch; do
            if [[ -f "$file" ]]; then
                log_message "INFO" "  -> Applying $(basename "$file")"
                patch --ignore-whitespace -N "-${patch_level}" < "$file"
            fi
        done
    fi
}

###
# @description Internal helper to generate configure arguments for Node.js.
# @param $1 string Full version (e.g., "18.17.1").
# @param $2 string Installation prefix.
# @return Fills the global array 'CONFIGURE_ARGS' with arguments.
###
_get_node_configure_args() {
    local version=$1
    local prefix=$2
    integer version_major_num=$(echo "$version" | awk -F. '{print $1}')
    
    # Start with common args
    CONFIGURE_ARGS=(
        "--prefix=${prefix}"
        "--ninja"
    )

    # Architecture-specific args
    if [[ "$architecture" == "arm64" ]]; then
        # For older versions on arm64 that require Python 2.7
        if (( version_major_num <= 13 )); then
            CONFIGURE_ARGS+=( "--dest-cpu=arm64" )
        fi
    fi
}

###
# @description Internal helper to generate cmake arguments for MySQL.
# @param $1 string Full version (e.g., "8.0.36").
# @param $2 string Installation prefix.
# @return Fills the global array 'CMAKE_ARGS' with arguments.
###
_get_mysql_cmake_args() {
    local version=$1
    local prefix=$2
    local version_major=$(echo "$version" | awk -F. '{print $1"."$2}')
    
    # Common CMake args for most versions
    CMAKE_ARGS=(
        "-DCMAKE_INSTALL_PREFIX=${prefix}"
        "-DMYSQL_DATADIR=${SERVBAY_DB_PATH}/mysql/${version_major}"
        "-DMYSQL_UNIX_ADDR=${SERVBAY_TMP_PATH}/mysql-${version_major}.sock"
        "-DDEFAULT_SYSCONFDIR=${SERVBAY_ETC_PATH}/mysql/${version_major}"
        "-DEXTRA_CHARSETS=all"
        "-DDEFAULT_CHARSET=utf8mb4"
        "-DDEFAULT_COLLATION=utf8mb4_general_ci"
        "-DENABLED_LOCAL_INFILE=1"
        "-DWITH_ZLIB=bundled"
        "-DWITH_EMBEDDED_SERVER=0"
        "-DWITH_DEBUG=0"
        "-DWITH_UNIT_TESTS=OFF"
        "-DCMAKE_MACOSX_RPATH=1"
        "-DCMAKE_OSX_DEPLOYMENT_TARGET=${BUILD_OS_MIN_VERSION}"
        "-DCMAKE_OSX_ARCHITECTURES=$(echo "$BUILD_CPU_ARCH" | awk '{print $2}')"
        "-DCOMPILATION_COMMENT=ServBay.dev"
    )

    # Version-specific CMake args
    case "$version_major" in
        "5.5")
            CMAKE_ARGS+=( "-DWITH_SSL=bundled" "-DCMAKE_CXX_STANDARD=98" )
            ;;
        "5.6")
            CMAKE_ARGS+=( "-DWITH_SSL=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}" "-DWITH_EDITLINE=bundled" "-DWITH_NUMA=OFF" "-DWITH_INNODB_MEMCACHED=ON" "-DOPENSSL_ROOT_DIR=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}" )
            ;;
        "5.7")
            CMAKE_ARGS+=( "-DWITH_SSL=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}" "-DWITH_LZ4=bundled" "-DWITH_PROTOBUF=bundled" "-DWITH_BOOST=./boost_1_59_0" "-DWITH_EDITLINE=bundled" "-DWITH_NUMA=OFF" "-DWITH_CURL=${SERVBAY_COMMON_PATH}" "-DWITH_INNODB_MEMCACHED=ON" )
            ;;
        "8.0"|"8.1"|"8.2"|"9.0"|"9.1"|"9.2"|"9.3")
            CMAKE_ARGS+=( "-DWITH_SYSTEM_LIBS=OFF" "-DWITH_SSL=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}" "-DWITH_LZ4=bundled" "-DWITH_PROTOBUF=bundled" "-DWITH_BOOST=./boost_1_77_0" "-DWITH_EDITLINE=bundled" "-DWITH_FIDO=bundled" "-DWITH_ICU=bundled" "-DWITH_ZSTD=bundled" "-DWITH_LIBEVENT=bundled" "-DWITH_NUMA=OFF" "-DWITH_CURL=${SERVBAY_COMMON_PATH}" "-DWITH_INNODB_MEMCACHED=ON" )
            ;;
        "8.3")
             CMAKE_ARGS+=( "-DWITH_SYSTEM_LIBS=OFF" "-DWITH_SSL=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}" "-DWITH_LZ4=bundled" "-DWITH_PROTOBUF=bundled" "-DWITH_EDITLINE=bundled" "-DWITH_FIDO=bundled" "-DWITH_ICU=bundled" "-DWITH_ZSTD=bundled" "-DWITH_LIBEVENT=bundled" "-DWITH_NUMA=OFF" "-DWITH_CURL=${SERVBAY_COMMON_PATH}" )
            ;;
        "8.4"|"9.4"|"9.5"|"9.6"|"9.7")
            CMAKE_ARGS=(
                "-DCMAKE_INSTALL_PREFIX=${prefix}"
                "-DMYSQL_DATADIR=${SERVBAY_DB_PATH}/mysql/${version_major}"
                "-DMYSQL_UNIX_ADDR=${SERVBAY_TMP_PATH}/mysql-${version_major}.sock"
                "-DDEFAULT_SYSCONFDIR=${SERVBAY_ETC_PATH}/mysql/${version_major}"
                "-DDEFAULT_CHARSET=utf8mb4"
                "-DDEFAULT_COLLATION=utf8mb4_general_ci"
                "-DENABLED_LOCAL_INFILE=1"
                "-DWITH_SYSTEM_LIBS=OFF"
                "-DWITH_SSL=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}"
                # Pin FindOpenSSL as well. MySQL Router's harness_tls runs its own
                # find_package(OpenSSL); without OPENSSL_ROOT_DIR it picks up the CI
                # runner's brew openssl@3, compiling tls_*_context.cc against 3.x
                # headers while everything else links the base's 1.1.1u -> undefined
                # OSSL_DECODER_*/OSSL_PARAM_*/SSL_CTX_set0_tmp_dh_pkey at link. 1.1.1u
                # is fully sufficient once the whole build uses it consistently.
                "-DOPENSSL_ROOT_DIR=${SERVBAY_COMMON_PATH}/openssl/${OPENSSL_VERSION}"
                "-DWITH_LZ4=bundled"
                "-DWITH_ZLIB=bundled"
                "-DWITH_PROTOBUF=bundled"
                "-DWITH_DEBUG=0"
                "-DWITH_EDITLINE=bundled"
                "-DWITH_FIDO=bundled"
                "-DWITH_ICU=bundled"
                "-DWITH_ZSTD=bundled"
                "-DWITH_NUMA=OFF"
                "-DCMAKE_MACOSX_RPATH=1"
                "-DCMAKE_OSX_DEPLOYMENT_TARGET=${BUILD_OS_MIN_VERSION}"
                "-DCMAKE_OSX_ARCHITECTURES=$(echo "$BUILD_CPU_ARCH" | awk '{print $2}')"
                "-DCOMPILATION_COMMENT=ServBay.dev"
                "-DWITH_CURL=${SERVBAY_COMMON_PATH}"
                "-DWITH_UNIT_TESTS=OFF"
            )
            ;;
    esac

    # MySQL 9.7 introduced OpenTelemetry-based telemetry (client plugin +
    # server component, see plugin/telemetry_client/CMakeLists.txt and
    # components/telemetry/CMakeLists.txt). Both link the OTLP HTTP exporter
    # -> opentelemetry_http_client_curl -> ext::curl. With WITH_CURL pointed
    # at ServBay's common prefix, cmake/curl.cmake's FIND_CUSTOM_CURL picks
    # up ServBay's *static* libcurl.a, but only propagates libcurl.a itself
    # into the curl_interface target -- not libcurl.a's private dependencies
    # (libnghttp2, libbrotli, ...). ServBay's libcurl was built with
    # --with-nghttp2, so linking telemetry_client.so fails with a flood of
    # undefined _nghttp2_* symbols at the very end of a 65-minute build.
    # ServBay is a local dev environment and never exports OTLP telemetry,
    # so disable both flavors. As a bonus this skips compiling the bundled
    # opentelemetry-cpp-1.23.0 (saves ~30 CI minutes).
    if [[ "$version_major" == "9.7" ]]; then
        CMAKE_ARGS+=(
            "-DWITH_MYSQL_CLIENT_TELEMETRY=OFF"
            "-DWITH_MYSQL_SERVER_TELEMETRY=OFF"
        )
    fi
}

