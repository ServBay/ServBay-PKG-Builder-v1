            verify_command="${SERVBAY_PACKAGE_FULL_PATH}/openjdk/${version_major}/${packageVersion}/bin/java -version 2>&1 | grep ${version_major}"
            ;;
        "maven")
            local version_major=$(echo "$packageVersion" | awk -F. '{print $1}')
            # Maven requires Java to run, so we verify by checking for version-specific jar files
            verify_command="ls ${SERVBAY_PACKAGE_FULL_PATH}/maven/${version_major}/${packageVersion}/lib/maven-core-${packageVersion}.jar"
